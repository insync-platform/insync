---
import Button from "../ui/Button.astro";
import { ArrowRight } from "@lucide/astro";

const {
  heading = "Klaar voor de klantreis van de toekomst?",
  text = "Plan direct een demo in en ontdek wat Insync voor jouw organisatie kan betekenen.",
} = Astro.props;
---

<section id="cta" class="py-20 sm:py-28">
  <div class="container">
    <div
      class="relative overflow-hidden rounded-3xl px-6 py-16 sm:px-16 sm:py-20 grain"
      data-aos="custom-zoom-in"
      data-aos-duration="800"
      data-aos-once="true"
    >
      <!-- Gradient background -->
      <div
        class="absolute inset-0 bg-gradient-to-br from-primary/10 via-secondary to-accent/5 -z-0"
        aria-hidden="true"
      >
      </div>
      <!-- Glow orbs -->
      <div class="absolute -top-24 -left-24 size-64 rounded-full bg-primary/15 blur-[80px]" aria-hidden="true"></div>
      <div class="absolute -bottom-24 -right-24 size-64 rounded-full bg-accent/10 blur-[80px]" aria-hidden="true"></div>

      <div class="relative z-10 max-w-[700px] mx-auto text-center">
        <h2 class="mb-4">{heading}</h2>
        <p class="text-lg text-muted-foreground mb-10">{text}</p>
        <Button href="/demo" size="lg" class="glow-primary">
          Demo inplannen
          <ArrowRight class="size-5" />
        </Button>
      </div>
    </div>
  </div>
</section>
