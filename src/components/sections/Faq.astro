---
import { ChevronDown } from "@lucide/astro";

const { eyebrow = "Veelgestelde vragen", heading = "Goed om te weten", faqs = [] } = Astro.props;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.a,
    },
  })),
};
---

<section id="faq" class="py-20 sm:py-28">
  <div class="container">
    <div
      class="max-w-3xl mx-auto text-center mb-12 lg:mb-16"
      data-aos="custom-fade-up"
      data-aos-duration="400"
      data-aos-once="true"
    >
      <span class="label mb-4 inline-block">{eyebrow}</span>
      <h2>{heading}</h2>
    </div>

    <div
      class="max-w-3xl mx-auto space-y-3"
      data-aos="custom-fade-up"
      data-aos-duration="400"
      data-aos-delay="100"
      data-aos-once="true"
    >
      {
        faqs.map((faq) => (
          <details class="group rounded-2xl border border-border/60 bg-white px-5 sm:px-6 transition-shadow [&[open]]:shadow-sm">
            <summary class="flex items-center justify-between gap-4 py-5 cursor-pointer list-none font-medium text-base sm:text-lg [&::-webkit-details-marker]:hidden">
              {faq.q}
              <ChevronDown class="size-5 text-muted-foreground shrink-0 transition-transform duration-200 group-open:rotate-180" />
            </summary>
            <p class="text-muted-foreground pb-5 -mt-1">{faq.a}</p>
          </details>
        ))
      }
    </div>

    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </div>
</section>
