---
import Layout from "../../layouts/Layout.astro";
import Cta from "../../components/sections/Cta.astro";
import { ArrowDown } from "@lucide/astro";
import Button from "../../components/ui/Button.astro";
import { Image } from "astro:assets";
import InsyncLaptopMockup from "../../assets/insync-laptop-mockup.webp";
import InsyncAiTools from "../../assets/insync-ai/tools.webp";
import InsyncAiInput from "../../assets/insync-ai/input.webp";
import InsyncAiOutput from "../../assets/insync-ai/output.webp";
import {
  MessageSquare,
  Zap,
  ShieldCheck,
  Lock,
  UserSearch,
  ClipboardCheck,
  Mail,
  Sparkles,
  ListTodo,
  FileSearch,
  FileText,
} from "@lucide/astro";

const features = [
  {
    title: "Chat én spraak",
    description:
      "Geef in gewone taal een opdracht — getypt of ingesproken. Insync AI begrijpt je intentie, in NL, EN en PL.",
    icon: MessageSquare,
  },
  {
    title: "Van opdracht naar actie",
    description: "Geen eindeloos klikken meer. Eén regel doet in seconden wat anders minuten kost.",
    icon: Zap,
  },
  {
    title: "Jij houdt de controle",
    description:
      "Opzoeken gaat automatisch. Elke wijziging zet de AI klaar en voer je pas door na jouw bevestiging.",
    icon: ShieldCheck,
  },
  {
    title: "Veilig op je backoffice",
    description:
      "Insync AI werkt bovenop je bestaande systeem (zoals Novulo of ANVA) via een beveiligde MCP-server. Je data blijft waar hij hoort.",
    icon: Lock,
  },
];

const workflows = [
  {
    title: "Klantdossier in één oogopslag",
    description:
      "Zoek een relatie en zie adres, polissen, schades, documenten en facturen in één keer.",
    icon: UserSearch,
  },
  {
    title: "Schade beoordelen",
    description: "Signalen, risicoscore en een aanbevolen actie bovenaan. Jij neemt de beslissing.",
    icon: ClipboardCheck,
  },
  {
    title: "E-mail in jouw huisstijl",
    description: "Laat de AI een nette e-mail opstellen en — na jouw akkoord — versturen.",
    icon: Mail,
  },
  {
    title: "Verrijken met externe bronnen",
    description: "RDW-kenteken, KvK en postcode → adres worden automatisch opgehaald.",
    icon: Sparkles,
  },
  {
    title: "Taken en notities",
    description: "Vastleggen en opvolgen, reactief én proactief — zonder van scherm te wisselen.",
    icon: ListTodo,
  },
  {
    title: "Polisvoorwaarden vergelijken",
    description: "Vergelijk voorwaarden, vat ze samen en stel vragen met bronvermelding.",
    icon: FileSearch,
  },
];

const comparison = [
  {
    title: "Vergelijken",
    description:
      "Vergelijk verzekeringen systematisch, met automatische controle van alle secties en een volledige vergelijkingstabel.",
    icon: FileSearch,
  },
  {
    title: "Samenvatten",
    description:
      "Krijg beknopte overzichten van de hoofddekkingen in klantgerichte taal, zonder jargon.",
    icon: FileText,
  },
  {
    title: "Vragen met bronvermelding",
    description:
      "Stel specifieke dekkingsvragen en krijg een duidelijk antwoord met exacte verwijzing naar de polis.",
    icon: MessageSquare,
  },
];
---

<Layout
  title="Insync AI"
  description="AI-werkplek voor verzekeraars, volmachten en adviseurs. Bedien je backoffice via chat of spraak, laat de AI het werk voorbereiden en bevestig elke wijziging zelf."
  softwareApplication={{
    name: "Insync AI",
    applicationCategory: "BusinessApplication",
    applicationSubCategory: "Insurance Backoffice Assistant",
    description:
      "AI-werkplek voor verzekeraars, volmachten en adviseurs die via chat of spraak rechtstreeks met de backoffice (Novulo, Anva) werkt. De AI bereidt acties voor; de medewerker bevestigt elke wijziging.",
    featureList: [
      "Backoffice bedienen via chat en spraak",
      "AI bereidt voor, medewerker bevestigt elke wijziging",
      "Beveiligde MCP-server integratie met Novulo en Anva",
      "Workflows: klantdossier, schade beoordelen, e-mail en taken",
      "Polisvoorwaarden vergelijken met bronvermelding",
      "Meertalig (NL, EN, PL)",
    ],
  }}
>
  <section id="hero" class="pt-16 sm:pt-24 2xl:pt-32 pb-16 sm:pb-28 overflow-x-clip">
    <div class="container">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-24">
        <div>
          <div class="space-y-4">
            <h1
              class="display text-center lg:text-left bg-clip-text text-transparent bg-gradient-to-t from-[#16136C] to-foreground mb-4 starting:opacity-0 starting:translate-y-2 transition-all duration-500 delay-150"
            >
              Geef de opdracht. Insync AI regelt het.
            </h1>
            <p
              class="text-center lg:text-left sm:text-lg mb-10 starting:opacity-0 starting:translate-y-2 transition-all duration-500 delay-300"
            >
              Een AI-assistent die in gewone taal met jouw backoffice werkt. Via chat of spraak
              zoekt, leest en regelt Insync AI je administratie — en bij elke wijziging houd jij de
              controle.
            </p>
          </div>

          <div
            class="flex flex-col justify-center lg:justify-start sm:flex-row gap-4 starting:opacity-0 starting:translate-y-2 transition-all duration-500 delay-450"
          >
            <Button href="/demo" size="lg" class="w-full lg:w-auto"> Demo inplannen </Button>
            <Button href="#how" variant="outline" size="lg" class="w-full lg:w-auto">
              <ArrowDown class="text-primary size-6" />
              Ontdek hoe het werkt
            </Button>
          </div>
        </div>
        <div class="aspect-video lg:aspect-square max-w-full lg:max-w-[600px] w-full">
          <Image
            src={InsyncLaptopMockup}
            alt="Insync AI"
            class="h-full w-full rounded-3xl object-cover"
            data-aos="custom-zoom-in"
            data-aos-duration="1000"
            data-aos-delay="600"
            data-aos-once="true"
          />
        </div>
      </div>
    </div>
  </section>

  <section id="features" class="py-20 sm:py-28">
    <div class="container">
      <div
        class="flex flex-col lg:flex-row justify-between items-end gap-4 lg:gap-10 mb-16"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-once="true"
      >
        <div class="lg:max-w-[600px]">
          <div class="text-primary font-medium mb-2">Voordelen voor kantoren</div>
          <h1>Wat Insync AI voor jou betekent</h1>
        </div>
        <p class="lg:max-w-[640px]">
          Van tijdrovende administratie naar directe actie — met de zekerheid dat jij het laatste
          woord houdt.
        </p>
      </div>

      <ul
        class="grid md:grid-cols-2 xl:grid-cols-4 border rounded-2xl"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-delay="200"
        data-aos-once="true"
      >
        {
          features.map((feature) => (
            <li class="flex p-6 border-b md:border-r md:nth-[2]:border-r-0 xl:nth-[2]:border-r md:nth-[3]:border-b-0 xl:nth-[4]:border-b-0 last:border-0">
              <feature.icon class="size-6 text-primary shrink-0 mt-0.5 mr-3" />
              <div>
                <div class="text-lg font-medium mb-1">{feature.title}</div>
                <p class="text-muted-foreground">{feature.description}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section id="how" class="bg-gradient-to-t from-muted to-muted/50 py-20 sm:py-28">
    <div class="container">
      <div class="flex flex-col items-center">
        <h1
          class="text-center max-w-[680px] mb-4"
          data-aos="custom-fade-up"
          data-aos-duration="400"
          data-aos-once="true"
        >
          Van opdracht naar actie — met jou aan de knoppen
        </h1>
        <p
          class="text-center text-muted-foreground max-w-[620px] mb-16"
          data-aos="custom-fade-up"
          data-aos-duration="400"
          data-aos-delay="100"
          data-aos-once="true"
        >
          Insync AI doet het zoek- en voorbereidingswerk. Lezen gebeurt direct, wijzigen pas na
          jouw akkoord.
        </p>
        <ul class="grid lg:grid-cols-3 gap-8 max-w-[1200px] w-full">
          <li
            data-aos="custom-fade-up"
            data-aos-duration="400"
            data-aos-delay="200"
            data-aos-once="true"
          >
            <div
              class="relative bg-background border rounded-2xl shadow-md overflow-hidden aspect-video mb-6 pt-4"
            >
              <div
                class="absolute h-1/2 inset-x-0 bottom-0 bg-gradient-to-t from-background to-transparent"
              >
              </div>
              <Image src={InsyncAiInput} alt="Insync AI invoer" class="h-full aspect-video mx-auto" />
            </div>
            <h2 class="h4 mb-2">1. Jij geeft een opdracht</h2>
            <p class="text-sm text-muted-foreground">
              Typ of spreek wat je wilt doen. Insync AI begrijpt natuurlijke taal en herkent je
              intentie.
            </p>
          </li>
          <li
            data-aos="custom-fade-up"
            data-aos-duration="400"
            data-aos-delay="300"
            data-aos-once="true"
          >
            <div
              class="relative bg-background border rounded-2xl shadow-md overflow-hidden aspect-video mb-6 pt-4"
            >
              <div
                class="absolute h-1/2 inset-x-0 bottom-0 bg-gradient-to-t from-background to-transparent"
              >
              </div>
              <Image src={InsyncAiTools} alt="Insync AI tools" class="h-full aspect-video mx-auto" />
            </div>
            <h2 class="h4 mb-2">2. Insync AI zet het klaar</h2>
            <p class="text-sm text-muted-foreground">
              De AI kiest de juiste backoffice-acties, haalt gegevens op en vult alles automatisch
              in.
            </p>
          </li>
          <li
            data-aos="custom-fade-up"
            data-aos-duration="400"
            data-aos-delay="400"
            data-aos-once="true"
          >
            <div
              class="relative bg-background border rounded-2xl shadow-md overflow-hidden aspect-video mb-6 pt-4"
            >
              <div
                class="absolute h-1/2 inset-x-0 bottom-0 bg-gradient-to-t from-background to-transparent"
              >
              </div>
              <Image src={InsyncAiOutput} alt="Insync AI resultaat" class="h-full aspect-video mx-auto" />
            </div>
            <h2 class="h4 mb-2">3. Jij bevestigt</h2>
            <p class="text-sm text-muted-foreground">
              Elke wijziging laat precies zien wat er verandert. Pas na jouw akkoord gaat het naar je
              backoffice.
            </p>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section id="workflows" class="py-20 sm:py-28">
    <div class="container">
      <div
        class="flex flex-col lg:flex-row justify-between items-end gap-4 lg:gap-10 mb-16"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-once="true"
      >
        <div class="lg:max-w-[600px]">
          <div class="text-primary font-medium mb-2">Eén werkplek, steeds meer workflows</div>
          <h1>Meer dan chat alleen</h1>
        </div>
        <p class="lg:max-w-[640px]">
          Naast vrij chatten met je backoffice bundelt Insync AI complete workflows die het werk van
          je medewerkers overnemen. We voegen er voortdurend nieuwe aan toe.
        </p>
      </div>

      <ul
        class="grid md:grid-cols-2 lg:grid-cols-3 gap-6"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-delay="200"
        data-aos-once="true"
      >
        {
          workflows.map((workflow) => (
            <li class="flex flex-col items-start p-6 border rounded-2xl">
              <div class="flex items-center justify-center text-primary border rounded-lg size-12 mb-4">
                <workflow.icon class="size-6" />
              </div>
              <h2 class="text-lg font-medium mb-1">{workflow.title}</h2>
              <p class="text-muted-foreground">{workflow.description}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section id="voorwaarden-vergelijker" class="bg-gradient-to-t from-muted to-muted/50 py-20 sm:py-28">
    <div class="container">
      <div class="flex flex-col items-center mb-16">
        <div class="text-primary font-medium mb-2 text-center">Uitgelichte workflow</div>
        <h1
          class="text-center max-w-[720px] mb-4"
          data-aos="custom-fade-up"
          data-aos-duration="400"
          data-aos-once="true"
        >
          Polisvoorwaarden vergelijken met AI
        </h1>
        <p
          class="text-center text-muted-foreground max-w-[640px]"
          data-aos="custom-fade-up"
          data-aos-duration="400"
          data-aos-delay="100"
          data-aos-once="true"
        >
          Upload je polisdocumenten; de AI herkent automatisch verzekeraar, product, type en
          dekking. Daarna vergelijk, analyseer en bevraag je de voorwaarden via een intelligente
          chat — met exacte bronvermelding.
        </p>
      </div>

      <ul
        class="grid md:grid-cols-3 gap-6"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-delay="200"
        data-aos-once="true"
      >
        {
          comparison.map((item) => (
            <li class="flex flex-col items-start p-6 bg-background border rounded-2xl">
              <div class="flex items-center justify-center text-primary border rounded-lg size-12 mb-4">
                <item.icon class="size-6" />
              </div>
              <h2 class="text-lg font-medium mb-1">{item.title}</h2>
              <p class="text-muted-foreground">{item.description}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <Cta
    heading="Ontdek hoe eenvoudig jouw werkdag kan worden"
    text="Plan een demo in en ervaar zelf hoe Insync AI je administratie overneemt — terwijl jij de controle houdt."
  />
</Layout>
