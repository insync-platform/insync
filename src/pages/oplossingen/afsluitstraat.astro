---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import Button from "../../components/ui/Button.astro";
import {
  ArrowRight,
  ArrowDown,
  Zap,
  Smile,
  Clock,
  Cable,
  Sparkles,
  Car,
  ShieldCheck,
} from "@lucide/astro";
import InsurancePortal from "../../assets/insurance-portal/home.webp";
import InsurancePortalConfiguration from "../../assets/insurance-portal/insurance-portal-configuration.webp";
import Flow from "../../assets/insurance-portal/flow.webp";
import Inbox from "../../assets/insurance-portal/inbox.webp";
import Cta from "../../components/sections/Cta.astro";
import Faq from "../../components/sections/Faq.astro";

const features = [
  {
    title: "Dynamisch en modulair",
    description: "Stel afsluitstraten in via productconfiguratie, zonder maatwerk.",
    icon: Zap,
  },
  {
    title: "Altijd beschikbaar",
    description: "Klanten sluiten 24/7 af, zonder afhankelijk te zijn van kantooruren.",
    icon: Clock,
  },
  {
    title: "Direct in je backoffice",
    description: "Elke aanvraag landt automatisch in je administratie én het klantportaal.",
    icon: Cable,
  },
  {
    title: "Meer tijd voor advies",
    description: "Minder administratie, meer ruimte voor persoonlijk contact.",
    icon: Smile,
  },
];

const novaPoints = [
  {
    title: "Minimale invoer",
    description: "Kenteken en adres worden automatisch verrijkt — je klant typt nauwelijks.",
    icon: Car,
  },
  {
    title: "Uitleg op maat",
    description: "Nova legt verzekeringstermen en dekkingsvragen uit op basis van de echte voorwaarden.",
    icon: Sparkles,
  },
  {
    title: "Heldere grenzen",
    description: "Geen persoonlijk advies en geen premie- of acceptatiebeloftes — daarvoor verwijst Nova door naar jou.",
    icon: ShieldCheck,
  },
];

const steps = [
  {
    title: "1. Afsluitstraat instellen",
    description:
      "Bepaal welke producten beschikbaar zijn — op basis van bestaande productconfiguratie. Geen maatwerk.",
    image: InsurancePortalConfiguration,
    alt: "Afsluitstraat configureren",
  },
  {
    title: "2. Klant stelt zelf samen",
    description:
      "De wizard past zich aan het product aan. Je klant kiest een dekking, vergelijkt de opties als keuzehulp en geeft akkoord.",
    image: Flow,
    alt: "Klant doorloopt de aanvraag",
  },
  {
    title: "3. Direct verwerkt",
    description:
      "De aanvraag gaat rechtstreeks je backoffice in en je klant stroomt door naar het klantportaal.",
    image: Inbox,
    alt: "Aanvraag verwerkt in de administratie",
  },
];

const faqs = [
  {
    q: "Hoe snel sluit een klant een verzekering af?",
    a: "In enkele minuten. Kenteken en adres worden automatisch verrijkt, dus je klant typt nauwelijks.",
  },
  {
    q: "Wat doet AI-assistent Nova precies?",
    a: "Nova legt verzekeringstermen en dekkingsvragen uit op basis van je echte voorwaarden. Ze geeft geen persoonlijk advies en geen premie- of acceptatiebeloftes.",
  },
  {
    q: "Komt een aanvraag automatisch in onze backoffice?",
    a: "Ja. Elke aanvraag landt direct in je administratie en de klant stroomt door naar het klantportaal.",
  },
  {
    q: "Bepalen we zelf welke producten beschikbaar zijn?",
    a: "Ja, via productconfiguratie — zonder maatwerk.",
  },
];
---

<Layout
  title="Digitale Afsluitstraat"
  description="Laat klanten 24/7 online verzekeringen aanvragen via een dynamische afsluitstraat met AI-begeleiding. In jouw huisstijl, direct gekoppeld aan je backoffice."
>
  <!-- Hero -->
  <section id="hero" class="pt-16 sm:pt-24 2xl:pt-32 pb-16 sm:pb-28 overflow-x-clip">
    <div class="container">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-24">
        <div>
          <div class="space-y-4">
            <span
              class="label inline-block starting:opacity-0 starting:translate-y-2 transition-all duration-500"
            >
              Afsluitstraat · voor je klanten
            </span>
            <h1
              class="display text-center lg:text-left bg-clip-text text-transparent bg-gradient-to-t from-[#16136C] to-foreground mb-4 starting:opacity-0 starting:translate-y-2 transition-all duration-500 delay-150"
            >
              Online afsluiten in minuten, met AI die meedenkt
            </h1>
            <p
              class="text-center lg:text-left sm:text-lg mb-10 starting:opacity-0 starting:translate-y-2 transition-all duration-500 delay-300"
            >
              Je klant kiest, vergelijkt en stelt zelf een verzekering samen — begeleid door een
              ingebouwde AI-assistent. In jouw huisstijl, direct gekoppeld aan je backoffice.
            </p>
          </div>

          <div
            class="flex flex-col justify-center lg:justify-start sm:flex-row gap-4 starting:opacity-0 starting:translate-y-2 transition-all duration-500 delay-450"
          >
            <Button href="/demo" size="lg" class="w-full lg:w-auto"> Demo inplannen </Button>
            <Button href="#features" variant="outline" size="lg" class="w-full lg:w-auto">
              <ArrowDown class="text-primary size-6" />
              Ontdek de voordelen
            </Button>
          </div>
        </div>
        <div
          class="grid place-items-center gradient-background lg:aspect-square w-full lg:w-auto h-[400px] lg:h-[440px] 2xl:h-[600px] lg:max-h-none border rounded-3xl mx-auto overflow-hidden shrink-0"
        >
          <Image
            src={InsurancePortal}
            alt="Afsluitstraat"
            class="w-[260px] lg:w-3/5 mt-6 lg:mt-16 starting:opacity-0 starting:translate-y-4 transition-all duration-1000"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Voordelen -->
  <section id="features" class="py-20 sm:py-28">
    <div class="container">
      <div
        class="flex flex-col lg:flex-row justify-between items-end gap-4 lg:gap-10 mb-16"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-once="true"
      >
        <div class="lg:max-w-[600px]">
          <div class="text-primary font-medium mb-2">Voordelen voor klanten en kantoren</div>
          <h2>Sneller en slimmer afsluiten</h2>
        </div>
        <p class="lg:max-w-[640px]">
          Van oriënteren tot aanvragen in één digitale flow — zonder handmatig werk voor jouw
          organisatie.
        </p>
      </div>

      <ul
        class="grid md:grid-cols-2 xl:grid-cols-4 border rounded-2xl"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-delay="200"
        data-aos-once="true"
      >
        {
          features.map((feature) => (
            <li class="flex p-6 border-b md:border-r md:nth-[2]:border-r-0 xl:nth-[2]:border-r md:nth-[3]:border-b-0 xl:nth-[4]:border-b-0 last:border-0">
              <feature.icon class="size-6 text-primary shrink-0 mt-0.5 mr-3" />
              <div>
                <div class="text-lg font-medium mb-1">{feature.title}</div>
                <p class="text-muted-foreground">{feature.description}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Nova — AI-assistent -->
  <section id="nova" class="py-20 sm:py-28 bg-gradient-to-t from-muted to-muted/50">
    <div class="container">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
        <div class="lg:w-1/2" data-aos="custom-fade-up" data-aos-duration="400" data-aos-once="true">
          <span class="label mb-3 inline-block">AI-assistent</span>
          <h2 class="mb-4">Nova begeleidt je klant door de aanvraag</h2>
          <p class="text-muted-foreground text-lg mb-8">
            Nova is geen losse chatbot, maar denkt mee in de flow. Ze kent het gekozen product, weet
            wat al is ingevuld en beantwoordt vragen op basis van jouw echte polisvoorwaarden.
          </p>
          <ul class="space-y-4">
            {
              novaPoints.map((point) => (
                <li class="flex gap-3">
                  <div class="flex items-center justify-center size-10 rounded-lg bg-secondary text-primary shrink-0">
                    <point.icon class="size-5" />
                  </div>
                  <div>
                    <div class="font-medium mb-0.5">{point.title}</div>
                    <p class="text-sm text-muted-foreground">{point.description}</p>
                  </div>
                </li>
              ))
            }
          </ul>
        </div>

        <div
          class="lg:w-1/2 w-full"
          data-aos="custom-zoom-in"
          data-aos-duration="400"
          data-aos-delay="200"
          data-aos-once="true"
        >
          <div class="rounded-3xl border bg-white shadow-lg p-5 max-w-sm mx-auto">
            <div class="flex items-center gap-2 pb-3 border-b">
              <div class="size-9 rounded-lg bg-primary/10 text-primary grid place-items-center">
                <Sparkles class="size-5" />
              </div>
              <div>
                <div class="font-medium text-sm">Nova</div>
                <div class="text-xs text-muted-foreground">Helpt bij je aanvraag</div>
              </div>
            </div>
            <div class="space-y-3 py-4">
              <div
                class="ml-auto bg-primary text-primary-foreground rounded-2xl rounded-tr-sm px-3.5 py-2.5 text-sm max-w-[85%]"
              >
                Wat betekent eigen risico?
              </div>
              <div class="bg-muted rounded-2xl rounded-tl-sm px-3.5 py-2.5 text-sm max-w-[92%]">
                Het eigen risico is het deel van een schade dat je zelf betaalt. Bij de WA+ dekking
                die je nu bekijkt is dat €150 per gebeurtenis.
              </div>
            </div>
            <div class="flex items-center gap-2 rounded-xl border bg-muted/40 px-3 py-2">
              <span class="text-sm text-muted-foreground">Stel Nova een vraag…</span>
              <ArrowRight class="size-4 text-primary ml-auto" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Hoe werkt het -->
  <section id="hoe-het-werkt" class="py-20 sm:py-28">
    <div class="container">
      <div class="flex flex-col items-center">
        <h2
          class="text-center max-w-[600px] mb-16"
          data-aos="custom-fade-up"
          data-aos-duration="400"
          data-aos-once="true"
        >
          Hoe werkt het?
        </h2>
        <ul class="grid lg:grid-cols-3 gap-8">
          {
            steps.map((step, i) => (
              <li
                data-aos="custom-fade-up"
                data-aos-duration="400"
                data-aos-delay={String(i * 200)}
                data-aos-once="true"
              >
                <div class="relative bg-background border rounded-2xl shadow-md overflow-hidden h-[320px] mb-6 pt-4">
                  <div class="absolute h-1/2 inset-x-0 bottom-0 bg-gradient-to-t from-background to-transparent" />
                  <Image src={step.image} alt={step.alt} class="w-[350px] mx-auto" />
                </div>
                <h3 class="h4 mb-2">{step.title}</h3>
                <p class="text-sm text-muted-foreground">{step.description}</p>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- Ecosysteem -->
  <section class="pb-4">
    <div class="container">
      <div
        class="flex flex-col sm:flex-row items-center justify-between gap-4 p-6 sm:p-8 rounded-3xl border border-border/60 bg-muted/30 max-w-5xl mx-auto"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-once="true"
      >
        <div>
          <h3 class="text-lg font-semibold mb-1">Afsluiten is stap één</h3>
          <p class="text-muted-foreground text-sm">
            Daarna beheert je klant alles verder in het klantportaal — één doorlopende klantreis.
          </p>
        </div>
        <Button href="/oplossingen/klantportaal" variant="outline" class="group shrink-0">
          Bekijk het klantportaal
          <ArrowRight class="size-5 group-hover:translate-x-0.5 duration-150" />
        </Button>
      </div>
    </div>
  </section>

  <Faq heading="Vragen over de afsluitstraat" faqs={faqs} />

  <Cta
    heading="Klaar om sneller en slimmer af te sluiten?"
    text="Vraag vrijblijvend een demo aan en ontdek hoe je binnen een week jouw afsluitstraat live hebt."
  />
</Layout>

<style>
  .gradient-background {
    background:
      linear-gradient(-45deg, hsl(var(--primary) / 0.25), transparent 50%),
      linear-gradient(45deg, hsl(var(--accent) / 0.25), transparent 50%);
  }
</style>
