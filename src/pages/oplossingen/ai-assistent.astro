---
import Layout from "../../layouts/Layout.astro";
import Cta from "../../components/sections/Cta.astro";
import Button from "../../components/ui/Button.astro";
import { Image } from "astro:assets";
import InsyncLaptopMockup from "../../assets/insync-laptop-mockup.webp";
import InsyncAiTools from "../../assets/insync-ai/tools.webp";
import InsyncAiOutput from "../../assets/insync-ai/output.webp";
import Documents from "../../assets/documents.webp";
import {
  ArrowRight,
  ArrowDown,
  Bot,
  Mic,
  MessageSquare,
  Users,
  ClipboardList,
  Mail,
  Database,
  Languages,
  FileSearch,
  ShieldCheck,
  FileText,
  CircleCheck,
  Plug,
  Eye,
} from "@lucide/astro";

const capabilities = [
  {
    title: "Klanten & dossiers",
    description: "Zoek en bekijk het volledige dossier in één keer.",
    icon: Users,
  },
  {
    title: "Schades & taken",
    description: "Aanmaken, bijwerken en opvolgen.",
    icon: ClipboardList,
  },
  {
    title: "Communicatie",
    description: "E-mail in jouw huisstijl, klaargezet.",
    icon: Mail,
  },
  {
    title: "Verrijking",
    description: "RDW-kenteken, KvK en postcode → adres.",
    icon: Database,
  },
  {
    title: "Spraak & talen",
    description: "Typ of spreek in — NL, EN en PL.",
    icon: Mic,
  },
];

const workflows = [
  {
    tabTitle: "Voorwaarden vergelijken",
    cardTitle: "Polisvoorwaarden vergelijken in seconden",
    description:
      "Laat AI twee of meer voorwaardendocumenten volledig lezen. Je krijgt de topverschillen met impact, een volledige vergelijkingstabel en bronvermelding per regel.",
    image: InsyncAiTools,
    imageAlt: "Voorwaarden vergelijken met AI",
    icon: FileSearch,
    color: "bg-primary/10 text-primary",
  },
  {
    tabTitle: "Schades beoordelen",
    cardTitle: "Schades beoordelen met overzicht",
    description:
      "De belangrijkste signalen, een risico-inschatting en een aanbevolen actie met onderbouwing. Jij accepteert of wijst af — mét waarschuwing bij kritieke punten.",
    image: InsyncAiOutput,
    imageAlt: "Schades beoordelen in Insync AI",
    icon: ShieldCheck,
    color: "bg-rose/10 text-rose",
  },
  {
    tabTitle: "Documentanalyse",
    cardTitle: "Documenten lezen en samenvatten",
    description:
      "Laat AI documenten doornemen, samenvatten of er gericht vragen over beantwoorden — met de bron erbij.",
    image: Documents,
    imageAlt: "Documentanalyse met AI",
    icon: FileText,
    color: "bg-accent/10 text-accent",
  },
];

const controlPoints = [
  {
    title: "Voorstel → bevestigen",
    description: "Elke wijziging toont eerst exact wat er verandert. Jij geeft akkoord.",
    icon: CircleCheck,
  },
  {
    title: "Afgebakende actielaag",
    description:
      "AI voert alleen vooraf gedefinieerde handelingen uit. Je data blijft in je backoffice.",
    icon: ShieldCheck,
  },
  {
    title: "Backoffice-onafhankelijk",
    description: "Productie op Novulo, daarnaast Anva en CCS.",
    icon: Plug,
  },
  {
    title: "Meertalig & multi-tenant",
    description: "NL, EN en PL, met rollen en rechten per kantoor.",
    icon: Languages,
  },
];

const steps = [
  {
    title: "Jij geeft een opdracht",
    description: "Typen of inspreken, in gewone taal.",
    icon: MessageSquare,
    color: "text-primary",
  },
  {
    title: "Insync AI kiest de handelingen",
    description: "En zet ze volledig voor je klaar.",
    icon: Bot,
    color: "text-rose",
  },
  {
    title: "Lezen direct, wijzigen met bevestiging",
    description: "Via de beveiligde actielaag.",
    icon: CircleCheck,
    color: "text-accent",
  },
];
---

<Layout
  title="Insync AI"
  description="De AI-werkplek voor verzekeraars, volmachten en adviseurs. Bedien je backoffice via chat of spraak — AI doet het voorwerk, jij beslist."
>
  <!-- Hero -->
  <section id="hero" class="pt-16 sm:pt-24 2xl:pt-32 pb-16 sm:pb-28 overflow-x-clip">
    <div class="container">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-24">
        <div>
          <div class="space-y-4">
            <span
              class="label inline-block starting:opacity-0 starting:translate-y-2 transition-all duration-500"
            >
              Insync AI · voor je medewerkers
            </span>
            <h1
              class="display text-center lg:text-left bg-clip-text text-transparent bg-gradient-to-t from-[#16136C] to-foreground mb-4 starting:opacity-0 starting:translate-y-2 transition-all duration-500 delay-150"
            >
              Geef de opdracht. Insync AI regelt het.
            </h1>
            <p
              class="text-center lg:text-left sm:text-lg mb-10 starting:opacity-0 starting:translate-y-2 transition-all duration-500 delay-300"
            >
              De AI-werkplek waar je team via chat of spraak de backoffice bedient. Vraag, zoek en
              regel in natuurlijke taal — AI doet het voorwerk, je medewerker beslist.
            </p>
          </div>

          <div
            class="flex flex-col justify-center lg:justify-start sm:flex-row gap-4 starting:opacity-0 starting:translate-y-2 transition-all duration-500 delay-450"
          >
            <Button href="/demo" size="lg" class="w-full lg:w-auto"> Demo inplannen </Button>
            <Button href="#chat" variant="outline" size="lg" class="w-full lg:w-auto">
              <ArrowDown class="text-primary size-6" />
              Ontdek hoe het werkt
            </Button>
          </div>
        </div>
        <div class="aspect-video lg:aspect-square max-w-full lg:max-w-[600px] w-full">
          <Image
            src={InsyncLaptopMockup}
            alt="Insync AI — werkplek voor medewerkers"
            class="h-full w-full rounded-3xl object-cover"
            data-aos="custom-zoom-in"
            data-aos-duration="1000"
            data-aos-delay="600"
            data-aos-once="true"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- De chat met je backoffice -->
  <section id="chat" class="py-20 sm:py-28">
    <div class="container">
      <div
        class="max-w-3xl mx-auto text-center mb-12"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-once="true"
      >
        <span class="label mb-4 inline-block">De kern</span>
        <h2 class="mb-4">Praat met je backoffice. In gewone taal.</h2>
        <p class="text-lg text-muted-foreground">
          Je typt of spreekt wat je nodig hebt; Insync AI kiest zelf de juiste handelingen in je
          systeem. Van een volledig klantdossier opzoeken tot een schade aanmaken, een taak
          klaarzetten of een e-mail in jouw huisstijl opstellen — alles vanuit één gesprek.
        </p>
      </div>

      <ul
        class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-delay="100"
        data-aos-once="true"
      >
        {
          capabilities.map((capability) => (
            <li class="flex gap-3 p-5 rounded-2xl border border-border/60 bg-white shadow-sm">
              <div class="flex items-center justify-center size-10 rounded-lg bg-secondary text-primary shrink-0">
                <capability.icon class="size-5" />
              </div>
              <div>
                <div class="font-medium mb-0.5">{capability.title}</div>
                <p class="text-sm text-muted-foreground">{capability.description}</p>
              </div>
            </li>
          ))
        }
      </ul>

      <div
        class="max-w-5xl mx-auto mt-5 flex flex-col sm:flex-row items-stretch gap-4"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-delay="200"
        data-aos-once="true"
      >
        <div
          class="flex-1 flex items-center gap-3 p-5 rounded-2xl border border-border/60 bg-muted/30"
        >
          <Eye class="size-5 text-primary shrink-0" />
          <span class="font-medium">Lezen: direct geregeld</span>
        </div>
        <div
          class="flex-1 flex items-center gap-3 p-5 rounded-2xl border border-primary/30 bg-primary/[0.04]"
        >
          <CircleCheck class="size-5 text-primary shrink-0" />
          <span class="font-medium">Wijzigen: jij bevestigt</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Workflows — interactieve stacked cards -->
  <section id="workflows" class="py-20 sm:py-28 bg-gradient-to-t from-muted to-muted/50">
    <div class="container">
      <div
        class="max-w-3xl mx-auto text-center mb-12"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-once="true"
      >
        <span class="label mb-4 inline-block">Meer dan chat</span>
        <h2 class="mb-4">Workflows die het denkwerk overnemen</h2>
        <p class="text-lg text-muted-foreground">
          Naast losse opdrachten pakt Insync AI hele klussen op. En we breiden dit continu uit.
        </p>
      </div>

      <div
        class="card-stack relative min-h-[28rem] pt-14 max-w-4xl mx-auto"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-delay="100"
        data-aos-once="true"
      >
        {
          workflows.map((workflow, i) => (
            <div
              class:list={[
                "card-stack-item absolute top-14 inset-x-0 min-h-96 flex flex-col bg-white rounded-[1.25rem] border-2 border-background shadow-lg overflow-hidden cursor-pointer",
                i === 0 && "is-front backdrop-blur-3xl bg-white/70 cursor-default",
              ]}
              style={`--stack-pos: ${i}; --stack-z: ${10 - i};`}
            >
              <div class="flex items-center gap-3 px-6 py-3.5 font-medium text-lg bg-[hsl(240_6%_95%)] rounded-t-[1.25rem] rounded-b-md border-b border-border/80">
                <div
                  class:list={[
                    "flex items-center justify-center size-9 rounded-lg shrink-0",
                    workflow.color,
                  ]}
                >
                  <workflow.icon class="size-5" />
                </div>
                <span>{workflow.tabTitle}</span>
              </div>
              <div class="flex flex-col lg:flex-row gap-8 overflow-hidden flex-1">
                <div class="lg:w-2/5 shrink-0 p-6 sm:p-8 pb-0 sm:pt-16">
                  <h4 class="text-2xl font-semibold mb-2">{workflow.cardTitle}</h4>
                  <p class="text-muted-foreground">{workflow.description}</p>
                </div>
                <div class="relative lg:w-3/5 mt-auto">
                  <Image
                    src={workflow.image}
                    alt={workflow.imageAlt}
                    class="w-full rounded-tl-xl border-l border-t bg-muted/30"
                    loading="lazy"
                  />
                  <div class="absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-white to-transparent pointer-events-none" />
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <div
        class="max-w-4xl mx-auto mt-12 flex flex-col sm:flex-row items-center justify-between gap-4 p-6 rounded-2xl border border-border/60 bg-white"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-once="true"
      >
        <p class="text-muted-foreground text-center sm:text-left">
          <span class="font-medium text-foreground">En er komt steeds meer bij.</span> Elke maand
          verschuift er werk van zelf doen naar laten regelen.
        </p>
        <Button href="/oplossingen/voorwaarden-vergelijker" variant="outline" class="group shrink-0">
          Bekijk de voorwaardenvergelijker
          <ArrowRight class="size-5 group-hover:translate-x-0.5 duration-150" />
        </Button>
      </div>
    </div>
  </section>

  <!-- Altijd in controle -->
  <section id="controle" class="py-20 sm:py-28">
    <div class="container">
      <div
        class="max-w-3xl mx-auto text-center mb-12 lg:mb-16"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-once="true"
      >
        <span class="label mb-4 inline-block">Veilig &amp; afgebakend</span>
        <h2 class="mb-4">Maximale snelheid, jij houdt de regie</h2>
        <p class="text-lg text-muted-foreground">
          Insync AI werkt razendsnel, maar nooit ongecontroleerd. Lezen gaat vanzelf; alles wat
          verandert, gaat via jou.
        </p>
      </div>

      <ul class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 max-w-6xl mx-auto">
        {
          controlPoints.map((point, i) => (
            <li
              class="p-6 rounded-2xl bg-white border border-border/60 shadow-sm"
              data-aos="custom-fade-up"
              data-aos-duration="400"
              data-aos-delay={String(i * 80)}
              data-aos-once="true"
            >
              <div class="flex items-center justify-center size-11 rounded-xl bg-primary/10 text-primary mb-4">
                <point.icon class="size-5" />
              </div>
              <h4 class="text-lg font-semibold mb-1.5">{point.title}</h4>
              <p class="text-muted-foreground text-sm">{point.description}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Hoe het werkt -->
  <section id="hoe-het-werkt" class="py-20 sm:py-28 bg-gradient-to-t from-muted to-muted/50">
    <div class="container">
      <div class="flex flex-col items-center">
        <h2
          class="text-center max-w-[600px] mb-16"
          data-aos="custom-fade-up"
          data-aos-duration="400"
          data-aos-once="true"
        >
          Van chat naar actie in seconden
        </h2>
        <ul class="grid lg:grid-cols-3 gap-6 lg:gap-8 max-w-5xl w-full">
          {
            steps.map((step, i) => (
              <li
                class="relative text-center p-6 sm:p-8 rounded-2xl bg-white border border-border/60 shadow-sm"
                data-aos="custom-fade-up"
                data-aos-duration="400"
                data-aos-delay={String(i * 100)}
                data-aos-once="true"
              >
                <div class="flex justify-center mb-5">
                  <div
                    class:list={[
                      "flex items-center justify-center size-14 rounded-2xl shadow-sm border border-border/60 bg-white",
                      step.color,
                    ]}
                  >
                    <step.icon class="size-6" />
                  </div>
                </div>
                <span
                  class:list={[
                    "text-xs font-semibold uppercase tracking-widest mb-3 block",
                    step.color,
                  ]}
                >
                  Stap {i + 1}
                </span>
                <h4 class="text-lg font-semibold mb-2">{step.title}</h4>
                <p class="text-muted-foreground text-sm">{step.description}</p>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <Cta
    heading="Ontdek hoe eenvoudig jouw werkdag kan worden"
    text="Plan een demo in en ervaar zelf hoe Insync AI je backoffice bestuurt via chat en spraak."
  />
</Layout>

<script is:inline>
  document.addEventListener("click", function (e) {
    var clicked = e.target.closest(".card-stack-item");
    if (!clicked || clicked.classList.contains("is-front")) return;

    var stack = clicked.closest(".card-stack");
    var cards = Array.from(stack.querySelectorAll(".card-stack-item"));

    cards.forEach(function (card) {
      card.classList.remove("is-front");
    });
    clicked.classList.add("is-front");

    var pos = 1;
    cards.forEach(function (card) {
      if (card === clicked) {
        card.style.setProperty("--stack-pos", "0");
        card.style.setProperty("--stack-z", "10");
      } else {
        card.style.setProperty("--stack-pos", String(pos));
        card.style.setProperty("--stack-z", String(10 - pos));
        pos++;
      }
    });
  });
</script>
