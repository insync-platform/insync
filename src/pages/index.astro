---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import InsyncAiOutput from "../assets/insync-ai/output.webp";
import CustomerPortal2 from "../assets/customer-portal/mockup.webp";
import IntegrationsHorizontal from "../assets/integrations-horizontal.svg";
import IntegrationsVertical from "../assets/integrations-vertical.svg";
import Background from "../assets/background.svg";
import LogoDuGardijn from "../assets/logos/du-gardijn.svg";
import LogoEfo from "../assets/logos/efo.svg";
import LogoJw from "../assets/logos/jw.svg";
import Button from "../components/ui/Button.astro";
import {
  ArrowRight,
  ArrowDown,
  MessageSquare,
  FileText,
  Mail,
  Phone,
  CircleCheck,
  Sparkles,
  Eye,
  ShieldCheck,
  Bot,
  Users,
  Mic,
  Palette,
  Plug,
} from "@lucide/astro";
import Cta from "../components/sections/Cta.astro";
import Faq from "../components/sections/Faq.astro";

const journeySteps = [
  {
    eyebrow: "Klantportaal",
    icon: Mic,
    title: "Klant meldt schade",
    description:
      "Via het klantportaal meldt de klant schade met de AI-assistent die het gesprek begeleidt.",
    color: "text-primary",
  },
  {
    eyebrow: "Insync AI",
    icon: ShieldCheck,
    title: "AI zet alles klaar",
    description:
      "De melding wordt automatisch gestructureerd en beoordeeld klaargezet voor de behandelaar.",
    color: "text-rose",
  },
  {
    eyebrow: "Medewerker beslist",
    icon: CircleCheck,
    title: "Eén klik en klaar",
    description:
      "De behandelaar ziet een onderbouwd voorstel en bevestigt — of past het aan waar nodig.",
    color: "text-accent",
  },
];

const trustPoints = [
  {
    title: "White-label",
    description:
      "Volledig in de huisstijl van elke verzekeraar. Eén fundament, meerdere merken.",
    icon: Palette,
  },
  {
    title: "Backoffice-onafhankelijk",
    description:
      "We koppelen met de backoffices die jij gebruikt, waaronder Novulo, Anva en CCS.",
    icon: Plug,
  },
  {
    title: "Privacy by design",
    description:
      "AVG-proof, met fijnmazige toestemming. Je data blijft waar 'ie hoort.",
    icon: ShieldCheck,
  },
];

const faqs = [
  {
    q: "Werkt Insync met onze backoffice?",
    a: "Insync werkt backoffice-onafhankelijk. We draaien in productie op Novulo en koppelen daarnaast met Anva en CCS.",
  },
  {
    q: "Raken we de controle kwijt aan de AI?",
    a: "Nee. AI zoekt en leest zelfstandig, maar elke wijziging zet 'ie alleen klaar — jouw medewerker bevestigt. Zo houd je altijd de regie.",
  },
  {
    q: "Hoe zit het met veiligheid en de AVG?",
    a: "Je data blijft in je eigen backoffice. De AI werkt via een afgebakende actielaag die precies bepaalt wat mag, en is privacy by design.",
  },
  {
    q: "Kunnen we het in onze eigen huisstijl aanbieden?",
    a: "Ja, volledig white-label. Eén fundament, jouw merk — per verzekeraar of label.",
  },
  {
    q: "Moeten we alles tegelijk afnemen?",
    a: "Nee. Je begint met de oplossing waar de winst het grootst is en breidt modulair uit.",
  },
];
---

<Layout>
  <!-- Hero -->
  <section id="hero" class="relative pt-28 sm:pt-36 2xl:pt-44 pb-20 sm:pb-28 overflow-hidden">
    <div
      class="absolute inset-x-0 top-0 h-svh -z-10"
      style="mask-image: linear-gradient(to bottom, black 60%, transparent);"
      aria-hidden="true"
    >
      <img
        src={Background.src}
        alt=""
        class="w-full h-full object-cover starting:opacity-0 starting:scale-120 transition-[opacity,scale] duration-2000 delay-800"
      />
    </div>

    <div class="container">
      <div class="max-w-4xl mx-auto text-center">
        <div
          class="starting:opacity-0 starting:translate-y-8 starting:scale-75 transition-all duration-500"
        >
          <div
            class="inline-flex items-center gap-2 rounded-xl border text-sm font-medium pl-1 py-1 pr-3 mb-6"
          >
            <span class="bg-foreground text-background rounded-lg inline-block px-2 py-1">Nieuw</span
            >
            Schade melden via onze AI-agent
          </div>
        </div>
        <h1
          class="display mb-6 starting:opacity-0 starting:translate-y-8 starting:scale-75 transition-all duration-800 delay-100"
        >
          Wij maken
          <span
            class="bg-clip-text text-transparent bg-gradient-to-r from-primary via-rose to-accent bg-[length:200%_auto] animate-[gradient-shift_6s_ease_infinite]"
          >
            verzekeren
          </span>
          makkelijker
        </h1>
        <p
          class="text-lg sm:text-xl text-muted-foreground max-w-2xl mx-auto mb-10 starting:opacity-0 starting:translate-y-8 starting:scale-75 transition-all duration-800 delay-200"
        >
          Voor verzekeraars, volmachten en adviseurs. Onze AI praat rechtstreeks met je backoffice en
          neemt het administratieve werk over — voor je medewerkers én je klanten. Minder klikken,
          meer regelen.
        </p>
        <div
          class="flex flex-col sm:flex-row justify-center gap-4 starting:opacity-0 starting:translate-y-8 starting:scale-75 transition-all duration-800 delay-300"
        >
          <Button href="/demo" size="lg" class="glow-primary" data-umami-event="Proefaccount CTA">
            Demo inplannen
            <ArrowRight class="size-5" />
          </Button>
          <Button href="/contact" size="lg" variant="outline" class="group"> Neem contact op </Button>
        </div>
      </div>

      <!-- Hero visual: opdracht -> actie concept (placeholder) -->
      <div
        id="hero-image"
        class="relative mt-12 sm:mt-16 mx-auto max-w-3xl will-change-transform starting:opacity-0 starting:translate-y-8 starting:scale-75 transition-[opacity,translate,scale] duration-1000 delay-500"
        style="transform: scale(0.85);"
      >
        <div class="relative rounded-2xl glow-primary bg-white border p-5 sm:p-7 text-left">
          <!-- Command -->
          <div class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-2">
            Jouw opdracht
          </div>
          <div class="flex items-start gap-3 rounded-xl border bg-muted/40 px-4 py-3">
            <Sparkles class="size-5 text-primary shrink-0 mt-0.5" />
            <p class="text-sm sm:text-base font-medium">
              "Wijzig het kenteken van Jan de Vries naar 12-ABC-3 en stuur hem een bevestiging."
            </p>
          </div>

          <!-- Connector -->
          <div class="flex items-center gap-3 my-4">
            <span
              class="inline-flex items-center gap-1.5 rounded-lg bg-primary/10 text-primary text-xs font-semibold px-2.5 py-1"
            >
              <Bot class="size-3.5" /> Insync AI
            </span>
            <span class="text-sm text-muted-foreground">handelt het af in je backoffice</span>
          </div>

          <!-- Actions -->
          <div class="space-y-2.5">
            <div class="flex items-center gap-3 rounded-xl border bg-background px-4 py-3">
              <span class="flex items-center justify-center size-7 rounded-lg bg-success/10 shrink-0">
                <Eye class="size-4 text-success" />
              </span>
              <span class="text-sm font-medium">Relatie opgehaald en kenteken gecontroleerd via RDW</span>
              <span class="ml-auto text-xs text-muted-foreground hidden sm:inline">Direct geregeld</span>
            </div>
            <div
              class="flex items-center gap-3 rounded-xl border border-primary/30 bg-primary/[0.04] px-4 py-3"
            >
              <span class="flex items-center justify-center size-7 rounded-lg bg-primary/10 shrink-0">
                <CircleCheck class="size-4 text-primary" />
              </span>
              <span class="text-sm font-medium">Wijziging en bevestigingsmail klaargezet</span>
              <span
                class="ml-auto inline-flex items-center gap-1.5 rounded-lg bg-primary text-primary-foreground text-xs font-semibold px-3 py-1.5"
              >
                Bevestigen
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Proof -->
  <section id="social-proof" class="py-12 sm:py-16">
    <div class="container">
      <div
        class="flex flex-col items-center"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-once="true"
      >
        <p class="text-sm font-medium text-muted-foreground mb-8">Vertrouwd door diverse partijen</p>
        <div class="flex items-center justify-center gap-12 sm:gap-20">
          <a href="https://dugardijn.nl" target="_blank">
            <img
              src={LogoDuGardijn.src}
              alt="Du Gardijn"
              class="h-8 sm:h-12 opacity-60 hover:opacity-100 transition-opacity duration-300"
            />
          </a>
          <a href="https://efo.nl" target="_blank">
            <img
              src={LogoEfo.src}
              alt="EFO Verzekeringen"
              class="h-8 sm:h-12 opacity-60 hover:opacity-100 transition-opacity duration-300"
            />
          </a>
          <a href="https://jw.nl" target="_blank">
            <img
              src={LogoJw.src}
              alt="JW"
              class="h-8 sm:h-12 opacity-60 hover:opacity-100 transition-opacity duration-300"
            />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Probleem — Statement + Before/After -->
  <section id="pain-points" class="py-24 sm:py-32 grain relative overflow-hidden">
    <div
      class="absolute inset-0 bg-gradient-to-br from-primary/[0.03] via-transparent to-accent/[0.02] -z-0"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute -top-32 -left-32 size-80 rounded-full bg-primary/[0.05] blur-[100px]"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute -bottom-32 -right-32 size-80 rounded-full bg-accent/[0.04] blur-[100px]"
      aria-hidden="true"
    >
    </div>

    <div class="container relative z-10">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
        <!-- Left: Statement -->
        <div
          class="max-md:flex max-md:flex-col max-md:items-center lg:w-3/5 text-center lg:text-left"
          data-aos="custom-fade-up"
          data-aos-duration="400"
          data-aos-once="true"
        >
          <h2 class="display !text-[2.25rem] sm:!text-[3rem] lg:!text-[3.5rem] mb-6">
            Verzekeren draait op administratie. Dat kan <span
              class="bg-clip-text text-transparent bg-gradient-to-r from-primary to-accent">anders</span
            >.
          </h2>
          <p class="text-lg sm:text-xl text-muted-foreground max-w-xl">
            Mutaties, schadedossiers, facturen, herhaalvragen — je team verliest er dagelijks uren
            aan. Werk dat de klant vaak prima zelf kan, of dat AI sneller doet. Insync neemt het over,
            bovenop je bestaande backoffice.
          </p>
        </div>

        <!-- Right: Before / After comparison -->
        <div class="lg:w-2/5 w-full flex flex-col items-center">
          <!-- Vandaag -->
          <div
            class="w-full p-6 rounded-2xl bg-muted/60 backdrop-blur-sm border border-border/60"
            data-aos="custom-fade-up"
            data-aos-duration="500"
            data-aos-delay="200"
            data-aos-once="true"
          >
            <div
              class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-5"
              data-aos="custom-fade-right"
              data-aos-duration="400"
              data-aos-delay="300"
              data-aos-once="true"
            >
              Vandaag
            </div>
            <ul class="space-y-3.5">
              <li
                class="flex items-center gap-3"
                data-aos="custom-fade-right"
                data-aos-duration="400"
                data-aos-delay="350"
                data-aos-once="true"
              >
                <FileText class="size-5 text-muted-foreground shrink-0" />
                <span class="font-medium">Mutaties handmatig invoeren</span>
              </li>
              <li
                class="flex items-center gap-3"
                data-aos="custom-fade-right"
                data-aos-duration="400"
                data-aos-delay="450"
                data-aos-once="true"
              >
                <Mail class="size-5 text-muted-foreground shrink-0" />
                <span class="font-medium">Herhaalvragen beantwoorden</span>
              </li>
              <li
                class="flex items-center gap-3"
                data-aos="custom-fade-right"
                data-aos-duration="400"
                data-aos-delay="550"
                data-aos-once="true"
              >
                <Phone class="size-5 text-muted-foreground shrink-0" />
                <span class="font-medium">Schades telefonisch intaken</span>
              </li>
            </ul>
          </div>

          <!-- Arrow connector -->
          <div
            class="my-4"
            data-aos="custom-draw-down"
            data-aos-duration="500"
            data-aos-delay="700"
            data-aos-once="true"
          >
            <ArrowDown class="size-5 text-primary animate-arrow-bob" aria-hidden="true" />
          </div>

          <!-- Met Insync -->
          <div
            class="relative w-full p-6 rounded-2xl bg-linear-to-br from-primary/15 via-primary/10 to-accent/10 border border-primary/30 shadow-lg shadow-primary/10 overflow-hidden"
            data-aos="custom-rise-pop"
            data-aos-duration="700"
            data-aos-delay="850"
            data-aos-once="true"
          >
            <Sparkles
              class="size-40 text-secondary/50 absolute bottom-0 right-0 translate-y-1/3 translate-x-1/3"
            />
            <div
              class="absolute -top-16 -right-16 size-40 rounded-full bg-primary/20 blur-3xl pointer-events-none animate-pulse-glow"
              aria-hidden="true"
            >
            </div>
            <div
              class="absolute -bottom-16 -left-16 size-32 rounded-full bg-accent/15 blur-3xl pointer-events-none animate-pulse-glow"
              style="animation-delay: 1.5s;"
              aria-hidden="true"
            >
            </div>

            <div class="relative flex items-center gap-2 mb-5">
              <span class="text-xs font-semibold uppercase tracking-widest text-primary">
                Met Insync
              </span>
            </div>

            <ul class="relative space-y-3">
              <li
                class="flex items-center gap-3"
                data-aos="custom-fade-right"
                data-aos-duration="400"
                data-aos-delay="1100"
                data-aos-once="true"
              >
                <div
                  class="flex items-center justify-center size-8 rounded-lg bg-white shadow-sm border border-primary/20 shrink-0"
                >
                  <CircleCheck class="size-4 text-primary" />
                </div>
                <span class="font-medium">Klant regelt het zelf in het portaal</span>
              </li>
              <li
                class="flex items-center gap-3"
                data-aos="custom-fade-right"
                data-aos-duration="400"
                data-aos-delay="1200"
                data-aos-once="true"
              >
                <div
                  class="flex items-center justify-center size-8 rounded-lg bg-white shadow-sm border border-primary/20 shrink-0"
                >
                  <MessageSquare class="size-4 text-primary" />
                </div>
                <span class="font-medium">AI beantwoordt vragen en zet acties klaar</span>
              </li>
              <li
                class="flex items-center gap-3"
                data-aos="custom-fade-right"
                data-aos-duration="400"
                data-aos-delay="1300"
                data-aos-once="true"
              >
                <div
                  class="flex items-center justify-center size-8 rounded-lg bg-white shadow-sm border border-primary/20 shrink-0"
                >
                  <ShieldCheck class="size-4 text-primary" />
                </div>
                <span class="font-medium">Mutaties en schades: AI doet het voorwerk, jij bevestigt</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Het idee — agentic AI op je backoffice -->
  <section id="het-idee" class="py-20 sm:py-28">
    <div class="container">
      <div
        class="max-w-3xl mx-auto text-center mb-14"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-once="true"
      >
        <span class="label mb-4 inline-block">Het idee</span>
        <h2 class="mb-4">AI die rechtstreeks met je backoffice praat</h2>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          De meeste software vraagt jóu om het werk te doen: klikken, zoeken, overtypen. Insync draait
          dat om. Je geeft een opdracht in gewone taal en onze agentic AI voert de handelingen uit in
          je backoffice. Geen los systeem ernaast — AI werkt rechtstreeks ín je administratie.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-5 max-w-4xl mx-auto">
        <div
          class="rounded-2xl bg-gradient-to-br from-primary via-rose to-accent p-[1.5px] shadow-sm shadow-primary/10"
          data-aos="custom-fade-up"
          data-aos-duration="400"
          data-aos-once="true"
        >
          <div class="h-full p-7 rounded-[15px] bg-white">
            <div class="flex items-center justify-center size-11 rounded-xl bg-success/10 text-success mb-4">
              <Eye class="size-5" />
            </div>
            <h4 class="text-lg font-semibold mb-1.5">Opzoeken en lezen? Direct geregeld.</h4>
            <p class="text-muted-foreground text-sm">
              AI haalt zelfstandig op wat nodig is: relaties, polissen, schades en documenten. Geen
              wachten, geen tussenstap.
            </p>
          </div>
        </div>
        <div
          class="rounded-2xl bg-gradient-to-br from-primary via-rose to-accent p-[1.5px] shadow-sm shadow-primary/10"
          data-aos="custom-fade-up"
          data-aos-duration="400"
          data-aos-delay="100"
          data-aos-once="true"
        >
          <div class="h-full p-7 rounded-[15px] bg-white">
            <div class="flex items-center justify-center size-11 rounded-xl bg-primary/10 text-primary mb-4">
              <CircleCheck class="size-5" />
            </div>
            <h4 class="text-lg font-semibold mb-1.5">Iets wijzigen? Jij bevestigt.</h4>
            <p class="text-muted-foreground text-sm">
              Elke wijziging zet AI volledig voor je klaar. Jij drukt op de knop. Zo blijf je altijd in
              controle.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Voor je medewerkers én je klanten -->
  <section id="medewerkers-klanten" class="py-20 sm:py-28 bg-muted/20 grain">
    <div class="container relative z-10">
      <div
        class="max-w-3xl mx-auto text-center mb-16"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-once="true"
      >
        <span class="label mb-4 inline-block">Voor je medewerkers én je klanten</span>
        <h2>Eén beweging, twee kanten van het werk</h2>
      </div>

      <div class="grid lg:grid-cols-2 gap-6 max-w-6xl mx-auto">
        <!-- Medewerkers -->
        <div
          class="flex flex-col rounded-3xl bg-white border border-border/60 shadow-sm overflow-hidden"
          data-aos="custom-fade-up"
          data-aos-duration="400"
          data-aos-once="true"
        >
          <div class="p-7 sm:p-9">
            <div class="flex items-center gap-2 mb-3">
              <span
                class="inline-flex items-center justify-center size-9 rounded-lg bg-primary/10 text-primary"
              >
                <Bot class="size-5" />
              </span>
              <span class="label !text-primary">Voor je medewerkers</span>
            </div>
            <h3 class="h4 !text-2xl font-semibold mb-3">Geef de opdracht. Insync AI regelt het.</h3>
            <p class="text-muted-foreground mb-6">
              Een werkplek waar je team via chat of spraak de backoffice bedient — klantgegevens
              opzoeken, polisvoorwaarden vergelijken, schades beoordelen, communicatie versturen. AI
              doet het voorwerk, je medewerker beslist. En het portaal groeit mee: elke maand
              verschuift er werk van zelf doen naar laten regelen.
            </p>
            <Button href="/oplossingen/ai-assistent" variant="outline" class="group">
              Ontdek Insync AI
              <ArrowRight class="size-5 group-hover:translate-x-0.5 duration-150" />
            </Button>
          </div>
          <div class="mt-auto px-7 sm:px-9">
            <Image
              src={InsyncAiOutput}
              alt="Insync AI — werkplek voor medewerkers"
              class="w-full rounded-t-xl border-l border-t border-r bg-muted/30"
              loading="lazy"
            />
          </div>
        </div>

        <!-- Klanten -->
        <div
          class="flex flex-col rounded-3xl bg-white border border-border/60 shadow-sm overflow-hidden"
          data-aos="custom-fade-up"
          data-aos-duration="400"
          data-aos-delay="100"
          data-aos-once="true"
        >
          <div class="p-7 sm:p-9">
            <div class="flex items-center gap-2 mb-3">
              <span
                class="inline-flex items-center justify-center size-9 rounded-lg bg-rose/10 text-rose"
              >
                <Users class="size-5" />
              </span>
              <span class="label !text-rose">Voor je klanten</span>
            </div>
            <h3 class="h4 !text-2xl font-semibold mb-3">Je klanten regelen het zelf, 24/7.</h3>
            <p class="text-muted-foreground mb-6">
              Een klantportaal in je eigen huisstijl waar klanten hun verzekeringen, documenten,
              facturen en schades zelf beheren. Minder telefoon en mail, meer gemak. Een ingebouwde
              AI-assistent die hun dossier kent helpt waar nodig: vragen beantwoorden, acties
              klaarzetten of direct regelen.
            </p>
            <Button href="/oplossingen/klantportaal" variant="outline" class="group">
              Ontdek het klantportaal
              <ArrowRight class="size-5 group-hover:translate-x-0.5 duration-150" />
            </Button>
          </div>
          <div class="mt-auto px-7 sm:px-9 flex justify-center bg-gradient-to-b from-transparent to-rose/[0.04]">
            <Image
              src={CustomerPortal2}
              alt="Klantportaal voor klanten"
              class="w-[240px] rounded-t-xl"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Zo werken de oplossingen samen -->
  <section id="platform" class="py-20 sm:py-28 relative overflow-hidden">
    <div class="container relative z-10">
      <div
        class="max-w-3xl mx-auto text-center mb-16"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-once="true"
      >
        <span class="label mb-4 inline-block">Drie oplossingen, één fundament</span>
        <h2 class="mb-4">Losse oplossingen die samen méér doen</h2>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          Insync AI, het klantportaal en de afsluitstraat zijn los inzetbaar — maar delen dezelfde
          data en dezelfde AI-laag. Zo loopt de hele klantreis in elkaar over: van oriënteren en
          afsluiten tot beheren en bedienen.
        </p>
      </div>

      <div class="max-w-5xl mx-auto relative">
        <div
          class="hidden md:block absolute top-[5.5rem] left-[calc(16.67%-0.5rem)] right-[calc(16.67%-0.5rem)] h-px bg-gradient-to-r from-primary/20 via-rose/20 to-accent/20 z-0"
          aria-hidden="true"
        >
        </div>

        <div class="grid md:grid-cols-3 gap-6 lg:gap-8 relative z-10">
          {
            journeySteps.map((step, i) => (
              <div
                class="relative"
                data-aos="custom-fade-up"
                data-aos-duration="400"
                data-aos-delay={String(i * 100)}
                data-aos-once="true"
              >
                <div class="flex justify-center mb-6">
                  <div
                    class:list={[
                      "flex items-center justify-center size-14 rounded-2xl shadow-sm border border-border/60 bg-white",
                      step.color,
                    ]}
                  >
                    <step.icon class="size-6" />
                  </div>
                </div>

                <div class="text-center p-6 sm:p-8 rounded-2xl bg-white border border-border/60 shadow-sm hover:shadow-md transition-shadow duration-300">
                  <span
                    class:list={[
                      "text-xs font-semibold uppercase tracking-widest mb-3 block",
                      step.color,
                    ]}
                  >
                    {step.eyebrow}
                  </span>
                  <h4 class="text-lg font-semibold mb-2">{step.title}</h4>
                  <p class="text-muted-foreground text-sm">{step.description}</p>
                </div>
              </div>
            ))
          }
        </div>

        <div
          class="mt-12 text-center"
          data-aos="custom-fade-up"
          data-aos-duration="400"
          data-aos-delay="300"
          data-aos-once="true"
        >
          <p class="text-sm text-muted-foreground">
            Dit is slechts één voorbeeld. Alle oplossingen zijn modulair inzetbaar en komen samen in
            één omgeving.
          </p>
        </div>
      </div>
    </div>
  </section>

