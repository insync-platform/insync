---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import InsyncAiOutput from "../assets/insync-ai/output.webp";
import CustomerPortal2 from "../assets/customer-portal/mockup.webp";
import IntegrationsHorizontal from "../assets/integrations-horizontal.svg";
import IntegrationsVertical from "../assets/integrations-vertical.svg";
import Background from "../assets/background.svg";
import LogoDuGardijn from "../assets/logos/du-gardijn.svg";
import LogoEfo from "../assets/logos/efo.svg";
import LogoJw from "../assets/logos/jw.svg";
import Button from "../components/ui/Button.astro";
import {
  ArrowRight,
  ArrowDown,
  MessageSquare,
  FileText,
  Mail,
  Phone,
  CircleCheck,
  Sparkles,
  Eye,
  ShieldCheck,
  Bot,
  Users,
  Mic,
  Palette,
  Plug,
  ShoppingCart,
  Check,
} from "@lucide/astro";
import Cta from "../components/sections/Cta.astro";
import Faq from "../components/sections/Faq.astro";

const scenarios = [
  {
    tab: "Schade melden",
    icon: ShieldCheck,
    accent: "text-primary",
    title: "Schade, van melding tot besluit",
    intro: "De klant meldt, AI bereidt voor, jij beslist.",
    steps: [
      {
        label: "Klantportaal",
        title: "Klant meldt schade",
        description: "Begeleid door de AI-schadewizard, in eigen woorden.",
      },
      {
        label: "Insync AI",
        title: "AI zet de beoordeling klaar",
        description: "Signalen, een risico-inschatting en een aanbevolen actie.",
      },
      {
        label: "Medewerker",
        title: "Bevestigen met één klik",
        description: "De behandelaar beslist; AI deed het voorwerk.",
      },
    ],
  },
  {
    tab: "Verzekering afsluiten",
    icon: ShoppingCart,
    accent: "text-rose",
    title: "Van oriënteren tot polis — online",
    intro: "De klant sluit zelf af; de aanvraag staat meteen in je backoffice.",
    steps: [
      {
        label: "Afsluitstraat",
        title: "Klant sluit online af",
        description: "Kiest, vergelijkt en vraagt aan, begeleid door Nova.",
      },
      {
        label: "Backoffice",
        title: "Aanvraag direct verwerkt",
        description: "Geen handmatig overtypen; alles staat klaar.",
      },
      {
        label: "Klantportaal",
        title: "Klant beheert verder",
        description: "Polis, documenten en facturen op één plek.",
      },
    ],
  },
  {
    tab: "Vraag van een klant",
    icon: MessageSquare,
    accent: "text-accent",
    title: "Elke klantvraag, direct opgepakt",
    intro: "Beantwoord of klaargezet — zonder dat jij hoeft te zoeken.",
    steps: [
      {
        label: "Klantportaal",
        title: "Klant stelt een vraag",
        description: "Via de ingebouwde assistent die het dossier kent.",
      },
      {
        label: "AI-assistent",
        title: "Antwoord of actie klaargezet",
        description: "Beantwoordt direct, of zet een actie klaar voor jou.",
      },
      {
        label: "Geregeld",
        title: "Direct of bevestigd",
        description: "Simpele acties meteen; de rest met jouw akkoord.",
      },
    ],
  },
];

const trustPoints = [
  {
    title: "White-label",
    description:
      "Volledig in de huisstijl van elke verzekeraar. Eén fundament, meerdere merken.",
    icon: Palette,
  },
  {
    title: "Backoffice-onafhankelijk",
    description:
      "We koppelen met de backoffices die jij gebruikt, waaronder Novulo, Anva en CCS.",
    icon: Plug,
  },
  {
    title: "Privacy by design",
    description:
      "AVG-proof, met gerichte toestemming. Je data blijft waar 'ie hoort.",
    icon: ShieldCheck,
  },
];

const faqs = [
  {
    q: "Werkt Insync met onze backoffice?",
    a: "Insync werkt backoffice-onafhankelijk en koppelt met je bestaande systemen, zoals Novulo, Anva en CCS.",
  },
  {
    q: "Raken we de controle kwijt aan de AI?",
    a: "Nee. AI zoekt en leest zelfstandig, maar elke wijziging zet 'ie alleen klaar — jouw medewerker bevestigt. Zo houd je altijd de regie.",
  },
  {
    q: "Hoe zit het met veiligheid en de AVG?",
    a: "Je data blijft in je eigen backoffice. De AI werkt via een afgebakende actielaag die precies bepaalt wat mag, en is privacy by design.",
  },
  {
    q: "Kunnen we het in onze eigen huisstijl aanbieden?",
    a: "Ja, volledig white-label. Eén fundament, jouw merk — per verzekeraar of label.",
  },
  {
    q: "Moeten we alles tegelijk afnemen?",
    a: "Nee. Je begint met de oplossing waar de winst het grootst is en breidt modulair uit.",
  },
];
---

<Layout>
  <!-- Hero -->
  <section id="hero" class="relative pt-28 sm:pt-36 2xl:pt-44 pb-20 sm:pb-28 overflow-hidden">
    <div
      class="absolute inset-x-0 top-0 h-svh -z-10"
      style="mask-image: linear-gradient(to bottom, black 60%, transparent);"
      aria-hidden="true"
    >
      <img
        src={Background.src}
        alt=""
        class="w-full h-full object-cover starting:opacity-0 starting:scale-120 transition-[opacity,scale] duration-2000 delay-800"
      />
    </div>

    <div class="container">
      <div class="max-w-4xl mx-auto text-center">
        <div
          class="starting:opacity-0 starting:translate-y-8 starting:scale-75 transition-all duration-500"
        >
          <div
            class="inline-flex items-center gap-2 rounded-xl border text-sm font-medium pl-1 py-1 pr-3 mb-6"
          >
            <span class="bg-foreground text-background rounded-lg inline-block px-2 py-1">Nieuw</span
            >
            Schade melden via onze AI-agent
          </div>
        </div>
        <h1
          class="display mb-6 starting:opacity-0 starting:translate-y-8 starting:scale-75 transition-all duration-800 delay-100"
        >
          Wij maken
          <span
            class="bg-clip-text text-transparent bg-gradient-to-r from-primary via-rose to-accent bg-[length:200%_auto] animate-[gradient-shift_6s_ease_infinite]"
          >
            verzekeren
          </span>
          makkelijker
        </h1>
        <p
          class="text-lg sm:text-xl text-muted-foreground max-w-2xl mx-auto mb-10 starting:opacity-0 starting:translate-y-8 starting:scale-75 transition-all duration-800 delay-200"
        >
          Voor verzekeraars, volmachten en adviseurs. Onze AI praat rechtstreeks met je backoffice en
          neemt het administratieve werk over — voor je medewerkers én je klanten. Minder klikken,
          meer regelen.
        </p>
        <div
          class="flex flex-col sm:flex-row justify-center gap-4 starting:opacity-0 starting:translate-y-8 starting:scale-75 transition-all duration-800 delay-300"
        >
          <Button href="/demo" size="lg" class="glow-primary" data-umami-event="Proefaccount CTA">
            Demo inplannen
            <ArrowRight class="size-5" />
          </Button>
          <Button href="/contact" size="lg" variant="outline" class="group"> Neem contact op </Button>
        </div>
      </div>

      <!-- Hero visual: Insync AI in app-frame met zwevende resultaatkaarten -->
      <div
        id="hero-image"
        class="relative mt-16 sm:mt-24 mx-auto max-w-2xl will-change-transform starting:opacity-0 starting:translate-y-8 starting:scale-75 transition-[opacity,translate,scale] duration-1000 delay-500"
        style="transform: scale(0.85);"
      >
        <!-- glow -->
        <div
          class="absolute -inset-8 -z-10 bg-gradient-to-tr from-primary/20 via-rose/10 to-accent/15 blur-3xl rounded-[3rem]"
          aria-hidden="true"
        >
        </div>

        <!-- App window -->
        <div class="relative rounded-2xl border bg-white shadow-2xl shadow-primary/10 overflow-hidden text-left">
          <!-- Top bar -->
          <div class="flex items-center gap-3 px-4 sm:px-5 py-3 border-b bg-muted/40">
            <div class="flex gap-1.5" aria-hidden="true">
              <span class="size-3 rounded-full bg-rose/40"></span>
              <span class="size-3 rounded-full bg-warning/40"></span>
              <span class="size-3 rounded-full bg-success/40"></span>
            </div>
            <div class="flex items-center gap-2 ml-1">
              <span class="flex items-center justify-center size-6 rounded-md bg-primary/10 text-primary">
                <Bot class="size-4" />
              </span>
              <span class="text-sm font-medium">Insync AI</span>
            </div>
            <span class="ml-auto hidden sm:flex items-center gap-1.5 text-xs text-muted-foreground">
              <span class="size-1.5 rounded-full bg-success"></span> Verbonden met backoffice
            </span>
          </div>

          <!-- Chat body -->
          <div class="p-4 sm:p-6 space-y-4">
            <div class="flex justify-end">
              <div
                class="max-w-[80%] bg-primary text-primary-foreground rounded-2xl rounded-tr-sm px-4 py-2.5 text-sm"
              >
                Werk het nieuwe adres van Jan de Vries bij en stuur hem een bevestiging.
              </div>
            </div>
            <div class="flex gap-2.5">
              <span
                class="flex items-center justify-center size-7 rounded-lg bg-primary/10 text-primary shrink-0 mt-0.5"
              >
                <Sparkles class="size-4" />
              </span>
              <div class="max-w-[85%] space-y-2.5">
                <div class="bg-muted rounded-2xl rounded-tl-sm px-4 py-2.5 text-sm">
                  Ik heb het adres opgehaald en de wijziging klaargezet. Even bevestigen?
                </div>
                <div class="rounded-xl border border-primary/30 bg-primary/[0.04] p-3">
                  <div class="text-xs text-muted-foreground mb-1">Wijziging klaargezet</div>
                  <div class="text-sm font-medium mb-3">Adres → Dorpsstraat 12, 3500 Utrecht</div>
                  <div class="flex gap-2">
                    <span
                      class="inline-flex items-center gap-1.5 rounded-lg bg-primary text-primary-foreground text-xs font-semibold px-3 py-1.5"
                    >
                      <CircleCheck class="size-3.5" /> Bevestigen
                    </span>
                    <span class="inline-flex items-center rounded-lg border text-xs font-medium px-3 py-1.5"
                      >Weigeren</span
                    >
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Input bar -->
          <div class="px-4 sm:px-5 py-3 border-t">
            <div class="flex items-center gap-2 rounded-xl border bg-muted/40 px-3.5 py-2.5">
              <span class="text-sm text-muted-foreground">Typ een opdracht…</span>
              <span
                class="ml-auto flex items-center justify-center size-7 rounded-lg bg-primary text-primary-foreground"
              >
                <ArrowRight class="size-4" />
              </span>
            </div>
          </div>
        </div>

        <!-- Floating result cards -->
        <div
          class="hidden sm:flex items-center gap-2.5 absolute -top-5 -right-4 lg:-right-10 rounded-xl border bg-white shadow-lg px-3.5 py-2.5 animate-float"
        >
          <span class="flex items-center justify-center size-7 rounded-lg bg-success/10 text-success">
            <CircleCheck class="size-4" />
          </span>
          <div class="text-xs">
            <div class="font-semibold">Adres bijgewerkt</div>
            <div class="text-muted-foreground">via RDW gecontroleerd</div>
          </div>
        </div>
        <div
          class="hidden sm:flex items-center gap-2.5 absolute -bottom-5 -left-4 lg:-left-10 rounded-xl border bg-white shadow-lg px-3.5 py-2.5 animate-float"
          style="animation-delay: 1.5s;"
        >
          <span class="flex items-center justify-center size-7 rounded-lg bg-primary/10 text-primary">
            <Mail class="size-4" />
          </span>
          <div class="text-xs">
            <div class="font-semibold">Bevestiging verstuurd</div>
            <div class="text-muted-foreground">in jouw huisstijl</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Proof -->
  <section id="social-proof" class="py-12 sm:py-16">
    <div class="container">
      <div
        class="flex flex-col items-center"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-once="true"
      >
        <p class="text-sm font-medium text-muted-foreground mb-8">Vertrouwd door diverse partijen</p>
        <div class="flex items-center justify-center gap-12 sm:gap-20">
          <a href="https://dugardijn.nl" target="_blank">
            <img
              src={LogoDuGardijn.src}
              alt="Du Gardijn"
              class="h-8 sm:h-12 opacity-60 hover:opacity-100 transition-opacity duration-300"
            />
          </a>
          <a href="https://efo.nl" target="_blank">
            <img
              src={LogoEfo.src}
              alt="EFO Verzekeringen"
              class="h-8 sm:h-12 opacity-60 hover:opacity-100 transition-opacity duration-300"
            />
          </a>
          <a href="https://jw.nl" target="_blank">
            <img
              src={LogoJw.src}
              alt="JW"
              class="h-8 sm:h-12 opacity-60 hover:opacity-100 transition-opacity duration-300"
            />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Probleem — Statement + Before/After -->
  <section id="pain-points" class="py-24 sm:py-32 grain relative overflow-hidden">
    <div
      class="absolute inset-0 bg-gradient-to-br from-primary/[0.03] via-transparent to-accent/[0.02] -z-0"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute -top-32 -left-32 size-80 rounded-full bg-primary/[0.05] blur-[100px]"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute -bottom-32 -right-32 size-80 rounded-full bg-accent/[0.04] blur-[100px]"
      aria-hidden="true"
    >
    </div>

    <div class="container relative z-10">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
        <!-- Left: Statement -->
        <div
          class="max-md:flex max-md:flex-col max-md:items-center lg:w-3/5 text-center lg:text-left"
          data-aos="custom-fade-up"
          data-aos-duration="400"
          data-aos-once="true"
        >
          <h2 class="display !text-[2.25rem] sm:!text-[3rem] lg:!text-[3.5rem] mb-6">
            Verzekeren draait op administratie. Dat kan <span
              class="bg-clip-text text-transparent bg-gradient-to-r from-primary to-accent">anders</span
            >.
          </h2>
          <p class="text-lg sm:text-xl text-muted-foreground max-w-xl">
            Je team verliest dagelijks uren aan handmatig, repeterend werk — werk dat de klant vaak
            zelf kan, of dat AI sneller doet. Insync neemt het over, bovenop je bestaande backoffice.
          </p>
        </div>

        <!-- Right: Before / After comparison -->
        <div class="lg:w-2/5 w-full flex flex-col items-center">
          <!-- Vandaag -->
          <div
            class="w-full p-6 rounded-2xl bg-muted/60 backdrop-blur-sm border border-border/60"
            data-aos="custom-fade-up"
            data-aos-duration="500"
            data-aos-delay="200"
            data-aos-once="true"
          >
            <div
              class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-5"
              data-aos="custom-fade-right"
              data-aos-duration="400"
              data-aos-delay="300"
              data-aos-once="true"
            >
              Vandaag
            </div>
            <ul class="space-y-3.5">
              <li
                class="flex items-center gap-3"
                data-aos="custom-fade-right"
                data-aos-duration="400"
                data-aos-delay="350"
                data-aos-once="true"
              >
                <FileText class="size-5 text-muted-foreground shrink-0" />
                <span class="font-medium">Handmatig overtypen tussen systemen</span>
              </li>
              <li
                class="flex items-center gap-3"
                data-aos="custom-fade-right"
                data-aos-duration="400"
                data-aos-delay="450"
                data-aos-once="true"
              >
                <Mail class="size-5 text-muted-foreground shrink-0" />
                <span class="font-medium">Herhaalvragen beantwoorden</span>
              </li>
              <li
                class="flex items-center gap-3"
                data-aos="custom-fade-right"
                data-aos-duration="400"
                data-aos-delay="550"
                data-aos-once="true"
              >
                <Phone class="size-5 text-muted-foreground shrink-0" />
                <span class="font-medium">Schades telefonisch intaken</span>
              </li>
            </ul>
          </div>

          <!-- Arrow connector -->
          <div
            class="my-4"
            data-aos="custom-draw-down"
            data-aos-duration="500"
            data-aos-delay="700"
            data-aos-once="true"
          >
            <ArrowDown class="size-5 text-primary animate-arrow-bob" aria-hidden="true" />
          </div>

          <!-- Met Insync -->
          <div
            class="relative w-full p-6 rounded-2xl bg-linear-to-br from-primary/15 via-primary/10 to-accent/10 border border-primary/30 shadow-lg shadow-primary/10 overflow-hidden"
            data-aos="custom-rise-pop"
            data-aos-duration="700"
            data-aos-delay="850"
            data-aos-once="true"
          >
            <Sparkles
              class="size-40 text-secondary/50 absolute bottom-0 right-0 translate-y-1/3 translate-x-1/3"
            />
            <div
              class="absolute -top-16 -right-16 size-40 rounded-full bg-primary/20 blur-3xl pointer-events-none animate-pulse-glow"
              aria-hidden="true"
            >
            </div>
            <div
              class="absolute -bottom-16 -left-16 size-32 rounded-full bg-accent/15 blur-3xl pointer-events-none animate-pulse-glow"
              style="animation-delay: 1.5s;"
              aria-hidden="true"
            >
            </div>

            <div class="relative flex items-center gap-2 mb-5">
              <span class="text-xs font-semibold uppercase tracking-widest text-primary">
                Met Insync
              </span>
            </div>

            <ul class="relative space-y-3">
              <li
                class="flex items-center gap-3"
                data-aos="custom-fade-right"
                data-aos-duration="400"
                data-aos-delay="1100"
                data-aos-once="true"
              >
                <div
                  class="flex items-center justify-center size-8 rounded-lg bg-white shadow-sm border border-primary/20 shrink-0"
                >
                  <CircleCheck class="size-4 text-primary" />
                </div>
                <span class="font-medium">Klant regelt het zelf in het portaal</span>
              </li>
              <li
                class="flex items-center gap-3"
                data-aos="custom-fade-right"
                data-aos-duration="400"
                data-aos-delay="1200"
                data-aos-once="true"
              >
                <div
                  class="flex items-center justify-center size-8 rounded-lg bg-white shadow-sm border border-primary/20 shrink-0"
                >
                  <MessageSquare class="size-4 text-primary" />
                </div>
                <span class="font-medium">AI beantwoordt vragen en zet acties klaar</span>
              </li>
              <li
                class="flex items-center gap-3"
                data-aos="custom-fade-right"
                data-aos-duration="400"
                data-aos-delay="1300"
                data-aos-once="true"
              >
                <div
                  class="flex items-center justify-center size-8 rounded-lg bg-white shadow-sm border border-primary/20 shrink-0"
                >
                  <ShieldCheck class="size-4 text-primary" />
                </div>
                <span class="font-medium">Routinewerk: AI doet het voorwerk, jij bevestigt</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Het idee — agentic AI op je backoffice -->
  <section id="het-idee" class="py-20 sm:py-28">
    <div class="container">
      <div
        class="max-w-3xl mx-auto text-center mb-14"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-once="true"
      >
        <span class="label mb-4 inline-block">Het idee</span>
        <h2 class="mb-4">AI die rechtstreeks met je backoffice praat</h2>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          AI neemt het werk over — vooraan, waar je klanten zelf zaken regelen, én achteraan, waar je
          team de backoffice bestuurt. Altijd in gewone taal, en altijd met jou aan de knoppen.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-5 max-w-5xl mx-auto">
        <div
          class="rounded-2xl bg-gradient-to-br from-primary via-rose to-accent p-[1.5px] shadow-sm shadow-primary/10"
          data-aos="custom-fade-up"
          data-aos-duration="400"
          data-aos-once="true"
        >
          <div class="h-full p-7 rounded-[15px] bg-white">
            <div class="flex items-center justify-center size-11 rounded-xl bg-primary/10 text-primary mb-4">
              <MessageSquare class="size-5" />
            </div>
            <h4 class="text-lg font-semibold mb-1.5">Vraag of opdracht in gewone taal</h4>
            <p class="text-muted-foreground text-sm">
              Een medewerker of klant zegt gewoon wat 'ie nodig heeft.
            </p>
          </div>
        </div>
        <div
          class="rounded-2xl bg-gradient-to-br from-primary via-rose to-accent p-[1.5px] shadow-sm shadow-primary/10"
          data-aos="custom-fade-up"
          data-aos-duration="400"
          data-aos-delay="100"
          data-aos-once="true"
        >
          <div class="h-full p-7 rounded-[15px] bg-white">
            <div class="flex items-center justify-center size-11 rounded-xl bg-success/10 text-success mb-4">
              <Eye class="size-5" />
            </div>
            <h4 class="text-lg font-semibold mb-1.5">AI doet het voorwerk</h4>
            <p class="text-muted-foreground text-sm">
              Opzoeken, lezen en klaarzetten — direct in je backoffice.
            </p>
          </div>
        </div>
        <div
          class="rounded-2xl bg-gradient-to-br from-primary via-rose to-accent p-[1.5px] shadow-sm shadow-primary/10"
          data-aos="custom-fade-up"
          data-aos-duration="400"
          data-aos-delay="200"
          data-aos-once="true"
        >
          <div class="h-full p-7 rounded-[15px] bg-white">
            <div class="flex items-center justify-center size-11 rounded-xl bg-primary/10 text-primary mb-4">
              <CircleCheck class="size-5" />
            </div>
            <h4 class="text-lg font-semibold mb-1.5">Jij bevestigt wat verandert</h4>
            <p class="text-muted-foreground text-sm">
              Lezen gaat vanzelf; elke wijziging gaat via een mens.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Voor je medewerkers én je klanten -->
  <section id="medewerkers-klanten" class="py-20 sm:py-28 bg-muted/20 grain">
    <div class="container relative z-10">
      <div
        class="max-w-3xl mx-auto text-center mb-16"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-once="true"
      >
        <span class="label mb-4 inline-block">Voor je medewerkers én je klanten</span>
