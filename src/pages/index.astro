<script>
  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // ===== Woord-voor-woord reveals =====
  const revealEls = Array.from(document.querySelectorAll(".reveal-words"));
  if (prefersReduced || !("IntersectionObserver" in window)) {
    revealEls.forEach((el) => el.classList.add("in-view"));
  } else {
    const revealObserver = new IntersectionObserver(
      (entries, observer) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("in-view");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.25 }
    );
    revealEls.forEach((el) => revealObserver.observe(el));
  }

  // ===== Spotlight: highlight volgt de muis =====
  document.addEventListener("pointermove", (e) => {
    const card = e.target instanceof Element ? e.target.closest("[data-spotlight]") : null;
    if (!(card instanceof HTMLElement)) return;
    const rect = card.getBoundingClientRect();
    card.style.setProperty("--mx", `${e.clientX - rect.left}px`);
    card.style.setProperty("--my", `${e.clientY - rect.top}px`);
  });

  // ===== Hero demo: scroll-tilt (perspectief vlakt uit bij scrollen) =====
  const demoWrap = document.getElementById("hero-demo-wrap");
  if (demoWrap && !prefersReduced) {
    let ticking = false;
    const updateTilt = () => {
      ticking = false;
      const rect = demoWrap.getBoundingClientRect();
      const viewportH = window.innerHeight;
      const center = rect.top + rect.height / 2;
      const progress = Math.max(
        0,
        Math.min(1, 1 - (center - viewportH * 0.45) / (viewportH * 0.55))
      );
      const tilt = (1 - progress) * 9;
      const scale = 0.9 + progress * 0.1;
      demoWrap.style.transform = `perspective(1200px) rotateX(${tilt.toFixed(2)}deg) scale(${scale.toFixed(4)})`;
    };
    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(updateTilt);
        }
      },
      { passive: true }
    );
    updateTilt();
  }

  // ===== Hero demo: zelfspelende loop =====
  const demo = document.getElementById("hero-demo");
  const typedEl = demo?.querySelector('[data-el="typed"]');
  if (demo && typedEl && !prefersReduced) {
    const MESSAGE = "Werk het nieuwe adres van Jan de Vries bij en stuur hem een bevestiging.";
    const PHASES: Array<[string, number]> = [
      ["typing", 0],
      ["sent", 950],
      ["thinking", 1500],
      ["reply", 1900],
      ["confirmed", 1500],
      ["done", 4200],
    ];
    let step = 0;
    let timer: ReturnType<typeof setTimeout> | undefined;
    let playing = false;
    let inView = false;

    const advance = () => {
      step = (step + 1) % PHASES.length;
      runStep();
    };
    const runStep = () => {
      const [phase, duration] = PHASES[step];
      demo.setAttribute("data-phase", phase);
      if (phase === "typing") {
        typedEl.textContent = "";
        let chars = 0;
        const type = () => {
          if (!playing) return;
          if (chars <= MESSAGE.length) {
            typedEl.textContent = MESSAGE.slice(0, chars);
            chars += 1;
            timer = setTimeout(type, 26);
          } else {
            timer = setTimeout(advance, 450);
          }
        };
        timer = setTimeout(type, 650);
      } else {
        timer = setTimeout(advance, duration);
      }
    };
    const sync = () => {
      const shouldPlay = inView && !document.hidden;
      if (shouldPlay && !playing) {
        playing = true;
        runStep();
      } else if (!shouldPlay && playing) {
        playing = false;
        clearTimeout(timer);
      }
    };
    new IntersectionObserver(
      ([entry]) => {
        inView = entry.isIntersecting;
        sync();
      },
      { threshold: 0.35 }
    ).observe(demo);
    document.addEventListener("visibilitychange", sync);
  }

  // ===== Scenario-tabs: crossfade, autoplay met pauze, toetsenbord =====
  const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>(".scenario-tab"));
  const panels = Array.from(document.querySelectorAll<HTMLElement>(".scenario-panel"));
  const tablist = document.getElementById("scenario-tablist");
  const scenarioCard = document.getElementById("scenario-card");
  if (tabs.length && panels.length) {
    const DURATION = 6000;
    let active = 0;
    let rotateTimer: ReturnType<typeof setInterval> | undefined;
    let hovering = false;
    let sectionInView = false;

    const autoplayAllowed = () => !prefersReduced && !hovering && sectionInView && !document.hidden;

    const paintProgress = () => {
      tabs.forEach((tab, i) => {
        const bar = tab.querySelector<HTMLElement>(".scenario-progress");
        if (!bar) return;
        bar.style.transition = "none";
        bar.style.width = i === active && prefersReduced ? "100%" : "0%";
        if (i === active && autoplayAllowed()) {
          void bar.offsetWidth;
          bar.style.transition = `width ${DURATION}ms linear`;
          bar.style.width = "100%";
        }
      });
    };

    const show = (i: number) => {
      active = i;
      tabs.forEach((tab, k) => {
        const selected = k === i;
        tab.setAttribute("aria-selected", String(selected));
        tab.tabIndex = selected ? 0 : -1;
      });
      panels.forEach((panel, k) => {
        panel.classList.toggle("is-active", k === i);
        if (k === i) panel.removeAttribute("inert");
        else panel.setAttribute("inert", "");
      });
      paintProgress();
    };

    const syncTimer = () => {
      if (rotateTimer) clearInterval(rotateTimer);
      rotateTimer = undefined;
      if (autoplayAllowed()) {
        rotateTimer = setInterval(() => show((active + 1) % tabs.length), DURATION);
      }
      paintProgress();
    };

    tabs.forEach((tab, i) => {
      tab.addEventListener("click", () => {
        show(i);
        syncTimer();
      });
    });

    tablist?.addEventListener("keydown", (e) => {
      let next: number | null = null;
      if (e.key === "ArrowRight" || e.key === "ArrowDown") next = (active + 1) % tabs.length;
      else if (e.key === "ArrowLeft" || e.key === "ArrowUp")
        next = (active - 1 + tabs.length) % tabs.length;
      else if (e.key === "Home") next = 0;
      else if (e.key === "End") next = tabs.length - 1;
      if (next !== null) {
        e.preventDefault();
        show(next);
        tabs[next].focus();
        syncTimer();
      }
    });

    if (scenarioCard) {
      scenarioCard.addEventListener("mouseenter", () => {
        hovering = true;
        syncTimer();
      });
      scenarioCard.addEventListener("mouseleave", () => {
        hovering = false;
        syncTimer();
      });
      new IntersectionObserver(
        ([entry]) => {
          sectionInView = entry.isIntersecting;
          syncTimer();
        },
        { threshold: 0.25 }
      ).observe(scenarioCard);
    }
    document.addEventListener("visibilitychange", syncTimer);

    show(0);
    syncTimer();
  }
</script>
