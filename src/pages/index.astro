        <h2>Gebouwd voor de verzekeringsbranche</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {
          advantages.map((advantage, i) => {
            const colors = [
              { border: "border-t-primary", icon: "bg-primary/10 text-primary" },
              { border: "border-t-rose", icon: "bg-rose/10 text-rose" },
              { border: "border-t-accent", icon: "bg-accent/10 text-accent" },
