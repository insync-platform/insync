---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import CustomerPortal from "../assets/customer-portal/home.webp";
import InsyncAiChat from "../assets/insync-ai/chat.png";
import CustomerPortal2 from "../assets/customer-portal/mockup.webp";
import InsurancePortalCar from "../assets/insurance-portal/car-insurance-mockup.webp";
import InsyncAiOutput from "../assets/insync-ai/output.webp";
import IntegrationsHorizontal from "../assets/integrations-horizontal.svg";
import IntegrationsVertical from "../assets/integrations-vertical.svg";
import Background from "../assets/background.svg";
import LogoEfo from "../assets/logos/efo.svg";
import LogoDuGardijn from "../assets/logos/du-gardijn.svg";
import Button from "../components/ui/Button.astro";
import {
  ArrowRight,
  ListChecks,
  MessageSquare,
  FileSearch,
  Search,
  Blocks,
  RefreshCw,
  ShieldCheck,
  Sparkles,
  Bot,
} from "@lucide/astro";
import InsyncAiInput from "../assets/insync-ai/input.webp";
import InsyncAiTools from "../assets/insync-ai/tools.webp";
import Cta from "../components/sections/Cta.astro";

const aiTools = [
  {
    icon: ListChecks,
    tabTitle: "Klantadvies Tool",
    cardTitle: "Persoonlijk advies op basis van klantdata",
    description:
      "Persoonlijk advies op basis van klantgegevens en actuele polisvoorwaarden. Altijd onderbouwd, altijd compliant.",
    image: InsyncAiOutput,
    imageAlt: "Klantadvies Tool — advies op basis van klantdata",
    color: "bg-primary/10 text-primary",
  },
  {
    icon: ShieldCheck,
    tabTitle: "Schade Analyse",
    cardTitle: "Schadeclaims beoordelen in minuten",
    description:
      "AI analyseert schademeldingen, toetst ze aan polisvoorwaarden en keurt simpele claims direct goed. Complexe schades worden voorzien van een advies voor de behandelaar.",
    image: InsyncAiOutput,
    imageAlt: "Schade Analyse — automatische beoordeling van schadeclaims",
    color: "bg-rose/10 text-rose",
  },
  {
    icon: FileSearch,
    tabTitle: "Voorwaarden Vergelijker",
    cardTitle: "Polisvoorwaarden vergelijken in seconden",
    description:
      "Upload polisdocumenten en vergelijk voorwaarden, dekkingen en uitsluitingen. Ook los te gebruiken.",
    image: InsyncAiTools,
    imageAlt: "Voorwaarden Vergelijker — polisvoorwaarden vergelijken met AI",
    color: "bg-accent/10 text-accent",
  },
];

const solutions = [
  {
    label: "Klantportaal",
    title: "Digitaal gemak met AI-ondersteuning",
    description:
      "Jouw klanten krijgen een persoonlijk portaal met inzicht in verzekeringen, documenten en schades. Schademeldingen worden begeleid door een AI speech agent die klanten door het proces praat, terwijl AI de melding direct analyseert voor de schadebehandelaar.",
    image: CustomerPortal2,
    imageAlt: "Klantportaal met AI schademelding via speech agent",
    href: "/oplossingen/klantportaal",
    cta: "Klantportaal ontdekken",
    reverse: false,
  },
  {
    label: "Afsluitstraat",
    title: "Verzekeringen afsluiten met AI-begeleiding",
    description:
      "Klanten sluiten eenvoudig online verzekeringen af via een dynamische flow. Een ingebouwde AI chat assistent helpt bij vragen, legt dekkingsopties uit en begeleidt klanten door het volledige aanvraagproces.",
    image: InsurancePortalCar,
    imageAlt: "Digitale afsluitstraat met AI chat assistent",
    href: "/oplossingen/afsluitstraat",
    cta: "Afsluitstraat ontdekken",
    reverse: true,
  },
];

const advantages = [
  {
    title: "Minder zoekwerk",
    description:
      "Stel een vraag in plaats van door vijf systemen te klikken. AI vindt het antwoord voor je.",
    icon: Search,
  },
  {
    title: "Altijd actueel",
    description:
      "Realtime data uit je backoffice. Geen handmatige exports of verouderde overzichten meer.",
    icon: RefreshCw,
  },
  {
    title: "Minder handwerk",
    description: "Schademeldingen, poliswijzigingen en documenten worden automatisch verwerkt.",
    icon: Sparkles,
  },
  {
    title: "Modulair platform",
    description: "Start met één oplossing. Uitbreiden kan altijd.",
    icon: Blocks,
  },
];
---

<Layout>
  <!-- Hero -->
  <section id="hero" class="relative pt-28 sm:pt-36 2xl:pt-44 pb-20 sm:pb-28 overflow-hidden">
    <div
      class="absolute inset-x-0 top-0 h-svh -z-10"
      style="mask-image: linear-gradient(to bottom, black 60%, transparent);"
      aria-hidden="true"
    >
      <img
        src={Background.src}
        alt=""
        class="w-full h-full object-cover starting:opacity-0 starting:scale-120 transition-[opacity,scale] duration-2000 delay-800"
      />
    </div>

    <div class="container">
      <div class="max-w-4xl mx-auto text-center">
        <div
          class="starting:opacity-0 starting:translate-y-8 starting:scale-75 transition-all duration-500"
        >
          <span class="label mb-6 inline-block">AI-first platform voor verzekeringen</span>
        </div>
        <h1
          class="display mb-6 starting:opacity-0 starting:translate-y-8 starting:scale-75 transition-all duration-800 delay-100"
        >
          De toekomst van
          <span
            class="bg-clip-text text-transparent bg-gradient-to-r from-primary via-rose to-accent bg-[length:200%_auto] animate-[gradient-shift_6s_ease_infinite]"
          >
            verzekeren
          </span>
          begint hier
        </h1>
        <p
          class="text-lg sm:text-xl text-muted-foreground max-w-2xl mx-auto mb-10 starting:opacity-0 starting:translate-y-8 starting:scale-75 transition-all duration-800 delay-200"
        >
          AI-tools voor adviseurs. Digitale oplossingen voor hun klanten.
        </p>
        <div
          class="flex flex-col sm:flex-row justify-center gap-4 starting:opacity-0 starting:translate-y-8 starting:scale-75 transition-all duration-800 delay-300"
        >
          <Button href="/demo" size="lg" class="glow-primary" data-umami-event="Proefaccount CTA">
            Demo inplannen
            <ArrowRight class="size-5" />
          </Button>
          <Button href="/contact" size="lg" variant="outline" class="group">
            Neem contact op
          </Button>
        </div>
      </div>

      <!-- Hero visual with scroll-based zoom -->
      <div
        id="hero-image"
        class="relative mt-8 sm:mt-12 mx-auto will-change-transform starting:opacity-0 starting:translate-y-8 starting:scale-75 transition-[opacity,translate,scale] duration-1000 delay-500"
        style="transform: scale(0.85);"
      >
        <div class="relative rounded-2xl overflow-hidden glow-primary">
          <Image
            src={InsyncAiChat}
            alt="Insync platform overzicht"
            class="w-full rounded-2xl aspect-video object-cover object-top"
            widths={[640, 960, 1400]}
            sizes="100vw"
          />
          <div
            class="absolute inset-0 bg-gradient-to-t from-background/20 via-transparent to-transparent pointer-events-none"
          >
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Proof -->
  <section id="social-proof" class="py-12 sm:py-16">
    <div class="container">
      <div
        class="flex flex-col items-center"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-once="true"
      >
        <p class="text-sm font-medium text-muted-foreground mb-8">
          Vertrouwd door toonaangevende intermediairs en verzekeraars
        </p>
        <div class="flex items-center justify-center gap-12 sm:gap-20">
          <img
            src={LogoEfo.src}
            alt="EFO Verzekeringen"
            class="h-8 sm:h-12 opacity-60 hover:opacity-100 transition-opacity duration-300"
          />
          <img
            src={LogoDuGardijn.src}
            alt="Du Gardijn"
            class="h-8 sm:h-12 opacity-60 hover:opacity-100 transition-opacity duration-300"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- AI Assistent -->
  <section id="ai-assistent" class="relative py-24 sm:py-32 grain">
    <div class="container relative z-10">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
        <div class="lg:w-1/2 text-center lg:text-left">
          <span
            class="label mb-4 inline-block"
            data-aos="custom-fade-up"
            data-aos-duration="400"
            data-aos-once="true">AI Assistent</span
          >
          <h2
            class="mb-4"
            data-aos="custom-fade-up"
            data-aos-duration="400"
            data-aos-delay="100"
            data-aos-once="true"
          >
            Jouw AI-gedreven backoffice assistent
          </h2>
          <p
            class="text-lg text-muted-foreground mb-8"
            data-aos="custom-fade-up"
            data-aos-duration="400"
            data-aos-delay="200"
            data-aos-once="true"
          >
            Stel vragen aan je backoffice in natuurlijke taal. Geen eindeloos klikken meer — je
            praat gewoon met het systeem en het handelt af.
          </p>
          <div
            data-aos="custom-fade-up"
            data-aos-duration="400"
            data-aos-delay="300"
            data-aos-once="true"
          >
            <Button href="/oplossingen/ai-assistent" size="lg" class="group">
              Ontdek de AI Assistent
              <ArrowRight class="size-5 group-hover:translate-x-0.5 duration-150" />
            </Button>
          </div>
        </div>
        <div
          class="lg:w-1/2"
          data-aos="custom-zoom-in"
          data-aos-duration="600"
          data-aos-delay="200"
          data-aos-once="true"
        >
          <div class="rounded-2xl overflow-hidden border bg-muted/30">
            <Image
              src={InsyncAiOutput}
              alt="AI Assistent — chat interface met backoffice koppeling"
              class="w-full"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- AI Tools -->
  <section id="ai-tools" class="py-20 sm:py-28">
    <div class="container">
      <div
        class="max-w-3xl mx-auto text-center mb-16"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-once="true"
      >
        <span class="label mb-4 inline-block">AI Tools</span>
        <h2>Slimme tools die het werk lichter maken</h2>
      </div>

      <div
        class="card-stack relative min-h-[28rem] pt-14 max-w-4xl mx-auto"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-delay="100"
        data-aos-once="true"
      >
        {
          aiTools.map((tool, i) => (
            <div
              class:list={[
                "card-stack-item absolute top-14 inset-x-0 min-h-96 flex flex-col bg-white rounded-[1.25rem] border-2 border-background shadow-lg overflow-hidden cursor-pointer",
                i === 0 && "is-front backdrop-blur-3xl bg-white/70 cursor-default",
              ]}
              style={`--stack-pos: ${i}; --stack-z: ${10 - i};`}
            >
              <div class="flex items-center gap-3 px-6 py-3.5 font-medium text-lg bg-[hsl(240_6%_95%)] rounded-t-[1.25rem] rounded-b-md border-b border-border/80">
                <div
                  class:list={[
                    "flex items-center justify-center size-9 rounded-lg shrink-0",
                    tool.color,
                  ]}
                >
                  <tool.icon class="size-5" />
                </div>
                <span>{tool.tabTitle}</span>
              </div>
              <div class="flex flex-col lg:flex-row gap-8 overflow-hidden flex-1">
                <div class="lg:w-2/5 shrink-0 p-6 sm:p-8 pb-0 sm:pt-16">
                  <h4 class="text-2xl font-semibold mb-2">{tool.cardTitle}</h4>
                  <p class="text-muted-foreground">{tool.description}</p>
                </div>
                <div class="relative lg:w-3/5 mt-auto">
                  <Image
                    src={tool.image}
                    alt={tool.imageAlt}
                    class="w-full rounded-tl-xl border-l border-t bg-muted/30"
                    loading="lazy"
                  />
                  <div class="absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-white to-transparent pointer-events-none" />
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Solutions: Klantportaal & Afsluitstraat -->
  {
    solutions.map((solution, i) => (
      <section class="py-20 sm:py-28">
        <div class="container">
          <div
            class:list={[
              "flex flex-col lg:flex-row justify-between items-center gap-16 lg:gap-24",
              { "lg:flex-row-reverse": solution.reverse },
            ]}
          >
            <div
              class="lg:max-w-[500px]"
              data-aos="custom-fade-up"
              data-aos-duration="400"
              data-aos-once="true"
            >
              <span class:list={["label mb-3 inline-block", solution.reverse && "text-rose"]}>
                {solution.label}
              </span>
              <h2 class="mb-4">{solution.title}</h2>
              <p class="text-muted-foreground text-lg leading-relaxed mb-8">
                {solution.description}
              </p>
              <Button href={solution.href} size="lg" variant="outline" class="group">
                {solution.cta}
                <ArrowRight class="size-5 group-hover:translate-x-0.5 duration-150" />
              </Button>
            </div>
            <div
              class="lg:max-w-[600px] w-full"
              data-aos="custom-zoom-in"
              data-aos-duration="400"
              data-aos-delay="200"
              data-aos-once="true"
            >
              <div class="rounded-2xl overflow-hidden border bg-muted/30">
                <Image
                  src={solution.image}
                  alt={solution.imageAlt}
                  class="w-full rounded-2xl"
                  loading="lazy"
                />
              </div>
            </div>
          </div>
        </div>
      </section>
    ))
  }

  <!-- Advantages -->
  <section id="advantages" class="py-20 sm:py-28 bg-muted/30 grain">
    <div class="container relative z-10">
      <div
        class="max-w-3xl mx-auto text-center mb-16"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-once="true"
      >
        <span class="label mb-4 inline-block">Waarom Insync</span>
        <h2>Gebouwd voor resultaat</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          advantages.map((advantage, i) => (
            <div
              class="glass-card p-6"
              data-aos="custom-fade-up"
              data-aos-duration="400"
              data-aos-delay={String(i * 80)}
              data-aos-once="true"
            >
              <div
                class:list={[
                  "flex items-center justify-center size-11 rounded-xl mb-4",
                  i % 2 === 0 ? "bg-primary/10 text-primary" : "bg-rose/10 text-rose",
                ]}
              >
                <advantage.icon class="size-5" />
              </div>
              <h4 class="text-lg font-semibold mb-1.5">{advantage.title}</h4>
              <p class="text-muted-foreground">{advantage.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Integrations -->
  <section id="integrations" class="py-20 sm:py-28">
    <div class="container">
      <div
        class="max-w-3xl mx-auto text-center mb-12 lg:mb-16"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-once="true"
      >
        <span class="label mb-4 inline-block">Integraties</span>
        <h2>Naadloos verbonden met jouw systeemlandschap</h2>
      </div>
    </div>
    <img
      src={IntegrationsHorizontal.src}
      alt="Integraties van Insync"
      class="hidden lg:block max-h-80 mx-auto"
      data-aos="custom-zoom-in"
      data-aos-duration="400"
      data-aos-delay="200"
      data-aos-once="true"
    />
    <img
      src={IntegrationsVertical.src}
      alt="Integraties van Insync"
      class="lg:hidden w-full max-w-[560px] mx-auto px-4"
      data-aos="custom-zoom-in"
      data-aos-duration="400"
      data-aos-delay="200"
      data-aos-once="true"
    />
  </section>

  <Cta />
</Layout>

<script is:inline>
  document.addEventListener("click", function (e) {
    var clicked = e.target.closest(".card-stack-item");
    if (!clicked || clicked.classList.contains("is-front")) return;

    var stack = clicked.closest(".card-stack");
    var cards = Array.from(stack.querySelectorAll(".card-stack-item"));

    // Move clicked card to front
    cards.forEach(function (card) {
      card.classList.remove("is-front");
    });
    clicked.classList.add("is-front");

    // Recalculate stack positions: front card = 0, rest ordered by DOM position
    var pos = 1;
    cards.forEach(function (card) {
      if (card === clicked) {
        card.style.setProperty("--stack-pos", "0");
        card.style.setProperty("--stack-z", "10");
      } else {
        card.style.setProperty("--stack-pos", String(pos));
        card.style.setProperty("--stack-z", String(10 - pos));
        pos++;
      }
    });
  });
</script>
