<script is:inline>
  (function () {
    const tabs = Array.from(document.querySelectorAll(".scenario-tab"));
    const panels = Array.from(document.querySelectorAll(".scenario-panel"));
    if (!tabs.length) return;

    const DURATION = 6000;
    let active = 0;
    let timer = null;

    function paintProgress() {
      tabs.forEach(function (tab, k) {
        const bar = tab.querySelector(".scenario-progress");
        if (!bar) return;
        bar.style.transition = "none";
        bar.style.width = "0%";
        if (k === active) {
          void bar.offsetWidth;
          bar.style.transition = "width " + DURATION + "ms linear";
          bar.style.width = "100%";
        }
      });
    }

    function show(i) {
      active = i;
      tabs.forEach(function (tab, k) {
        tab.setAttribute("aria-selected", k === i ? "true" : "false");
      });
      panels.forEach(function (panel, k) {
        panel.hidden = k !== i;
      });
      paintProgress();
    }

    function next() {
      show((active + 1) % tabs.length);
    }

    function startTimer() {
      if (timer) clearInterval(timer);
      timer = setInterval(next, DURATION);
    }

    function stopTimer() {
      if (timer) clearInterval(timer);
      timer = null;
    }

    tabs.forEach(function (tab, i) {
      tab.addEventListener("click", function () {
        show(i);
        startTimer();
      });
    });

    const panelsWrap = document.getElementById("scenario-panels");
    if (panelsWrap && panelsWrap.parentElement) {
      const wrap = panelsWrap.parentElement;
      wrap.addEventListener("mouseenter", stopTimer);
      wrap.addEventListener("mouseleave", startTimer);
    }

    show(0);
    startTimer();
  })();
</script>
