---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import InsyncAiOutput from "../assets/insync-ai/output.webp";
import CustomerPortal2 from "../assets/customer-portal/mockup.webp";
import IntegrationsHorizontal from "../assets/integrations-horizontal.svg";
import IntegrationsVertical from "../assets/integrations-vertical.svg";
import Background from "../assets/background.svg";
import LogoDuGardijn from "../assets/logos/du-gardijn.svg";
import LogoEfo from "../assets/logos/efo.svg";
import LogoJw from "../assets/logos/jw.svg";
import Button from "../components/ui/Button.astro";
import {
  ArrowRight,
  MessageSquare,
  FileText,
  Mail,
  Phone,
  CircleCheck,
  Sparkles,
  Eye,
  ShieldCheck,
  Bot,
  Users,
  Palette,
  Plug,
  ShoppingCart,
  Check,
} from "@lucide/astro";
import Cta from "../components/sections/Cta.astro";
import Faq from "../components/sections/Faq.astro";

const scenarios = [
  {
    tab: "Schade melden",
    icon: ShieldCheck,
    accent: "text-primary",
    title: "Schade, van melding tot besluit",
    intro: "De klant meldt, AI bereidt voor, jij beslist.",
    steps: [
      {
        label: "Klantportaal",
        title: "Klant meldt schade",
        description: "Begeleid door de AI-schadewizard, in eigen woorden.",
      },
      {
        label: "Insync AI",
        title: "AI zet de beoordeling klaar",
        description: "Signalen, een risico-inschatting en een aanbevolen actie.",
      },
      {
        label: "Medewerker",
        title: "Bevestigen met één klik",
        description: "De behandelaar beslist; AI deed het voorwerk.",
      },
    ],
  },
  {
    tab: "Verzekering afsluiten",
    icon: ShoppingCart,
    accent: "text-rose",
    title: "Van oriënteren tot polis — online",
    intro: "De klant sluit zelf af; de aanvraag staat meteen in je backoffice.",
    steps: [
      {
        label: "Afsluitstraat",
        title: "Klant sluit online af",
        description: "Kiest, vergelijkt en vraagt aan, begeleid door Nova.",
      },
      {
        label: "Backoffice",
        title: "Aanvraag direct verwerkt",
        description: "Geen handmatig overtypen; alles staat klaar.",
      },
      {
        label: "Klantportaal",
        title: "Klant beheert verder",
        description: "Polis, documenten en facturen op één plek.",
      },
    ],
  },
  {
    tab: "Vraag van een klant",
    icon: MessageSquare,
    accent: "text-accent",
    title: "Elke klantvraag, direct opgepakt",
    intro: "Beantwoord of klaargezet — zonder dat jij hoeft te zoeken.",
    steps: [
      {
        label: "Klantportaal",
        title: "Klant stelt een vraag",
        description: "Via de ingebouwde assistent die het dossier kent.",
      },
      {
        label: "AI-assistent",
        title: "Antwoord of actie klaargezet",
        description: "Beantwoordt direct, of zet een actie klaar voor jou.",
      },
      {
        label: "Geregeld",
        title: "Direct of bevestigd",
        description: "Simpele acties meteen; de rest met jouw akkoord.",
      },
    ],
  },
];

const ideaSteps = [
  {
    number: "01",
    title: "Vraag of opdracht in gewone taal",
    description: "Een medewerker of klant zegt gewoon wat 'ie nodig heeft.",
    icon: MessageSquare,
    color: "bg-primary/10 text-primary",
  },
  {
    number: "02",
    title: "AI doet het voorwerk",
    description: "Opzoeken, lezen en klaarzetten — direct in je backoffice.",
    icon: Eye,
    color: "bg-success/10 text-success",
  },
  {
    number: "03",
    title: "Jij bevestigt wat verandert",
    description: "Lezen gaat vanzelf; elke wijziging gaat via een mens.",
    icon: CircleCheck,
    color: "bg-primary/10 text-primary",
  },
];

const trustPoints = [
  {
    title: "White-label",
    description:
      "Volledig in de huisstijl van elke verzekeraar. Eén fundament, meerdere merken.",
    icon: Palette,
  },
  {
    title: "Backoffice-onafhankelijk",
    description:
      "We koppelen met de backoffices die jij gebruikt, waaronder Novulo, Anva en CCS.",
    icon: Plug,
  },
  {
    title: "Privacy by design",
    description:
      "AVG-proof, met gerichte toestemming. Je data blijft waar 'ie hoort.",
    icon: ShieldCheck,
  },
];

const logos = [
  { src: LogoDuGardijn.src, alt: "Du Gardijn", href: "https://dugardijn.nl" },
  { src: LogoEfo.src, alt: "EFO Verzekeringen", href: "https://efo.nl" },
  { src: LogoJw.src, alt: "JW", href: "https://jw.nl" },
];

const faqs = [
  {
    q: "Werkt Insync met onze backoffice?",
    a: "Insync werkt backoffice-onafhankelijk en koppelt met je bestaande systemen, zoals Novulo, Anva en CCS.",
  },
  {
    q: "Raken we de controle kwijt aan de AI?",
    a: "Nee. AI zoekt en leest zelfstandig, maar elke wijziging zet 'ie alleen klaar — jouw medewerker bevestigt. Zo houd je altijd de regie.",
  },
  {
    q: "Hoe zit het met veiligheid en de AVG?",
    a: "Je data blijft in je eigen backoffice. De AI werkt via een afgebakende actielaag die precies bepaalt wat mag, en is privacy by design.",
  },
  {
    q: "Kunnen we het in onze eigen huisstijl aanbieden?",
    a: "Ja, volledig white-label. Eén fundament, jouw merk — per verzekeraar of label.",
  },
  {
    q: "Moeten we alles tegelijk afnemen?",
    a: "Nee. Je begint met de oplossing waar de winst het grootst is en breidt modulair uit.",
  },
];
---

<Layout>
  <!-- Hero -->
  <section id="hero" class="relative pt-28 sm:pt-36 2xl:pt-44 pb-20 sm:pb-28 overflow-hidden">
    <!-- Atmosphere: brand backdrop, dot grid, drifting aurora -->
    <div
      class="absolute inset-x-0 top-0 h-svh -z-10"
      style="mask-image: linear-gradient(to bottom, black 60%, transparent);"
      aria-hidden="true"
    >
      <img
        src={Background.src}
        alt=""
        class="w-full h-full object-cover motion-safe:starting:opacity-0 motion-safe:starting:scale-110 transition-[opacity,scale] duration-2000 delay-700"
      />
    </div>
    <div
      class="absolute inset-0 -z-10 bg-[radial-gradient(circle,hsl(var(--primary)/0.13)_1px,transparent_1.5px)] bg-[length:26px_26px] [mask-image:radial-gradient(ellipse_55%_45%_at_50%_28%,black_25%,transparent_75%)]"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute -top-16 left-[8%] size-[26rem] rounded-full bg-primary/10 blur-[110px] animate-aurora -z-10"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute top-36 right-[6%] size-[22rem] rounded-full bg-accent/[0.07] blur-[100px] animate-aurora [animation-delay:-8s] -z-10"
      aria-hidden="true"
    >
    </div>

    <div class="container">
      <div class="max-w-4xl mx-auto text-center">
        <div
          class="motion-safe:starting:opacity-0 motion-safe:starting:translate-y-6 transition-all duration-700"
        >
          <div
            class="shimmer inline-flex items-center gap-2 rounded-xl border border-border/70 bg-white/60 backdrop-blur-sm shadow-sm text-sm font-medium pl-1 py-1 pr-3 mb-6"
          >
            <span class="bg-foreground text-background rounded-lg inline-block px-2 py-1">Nieuw</span
            >
            Schade melden via onze AI-agent
          </div>
        </div>
        <h1 class="display text-balance mb-6 reveal-words">
          <span class="word" style="--i:0">Wij</span>
          <span class="word" style="--i:1">maken</span>
          <span
            class="word bg-clip-text text-transparent bg-gradient-to-r from-primary via-rose to-accent bg-[length:200%_auto] animate-[gradient-shift_6s_ease_infinite]"
            style="--i:2">verzekeren</span
          >
          <span class="word" style="--i:3">makkelijker</span>
        </h1>
        <p
          class="text-lg sm:text-xl text-muted-foreground text-pretty max-w-2xl mx-auto mb-10 motion-safe:starting:opacity-0 motion-safe:starting:translate-y-6 transition-all duration-700 delay-300"
        >
          Voor verzekeraars, volmachten en adviseurs. Onze AI praat rechtstreeks met je backoffice en
          neemt het administratieve werk over — voor je medewerkers én je klanten. Minder klikken,
          meer regelen.
        </p>
        <div
          class="flex flex-col sm:flex-row justify-center gap-4 motion-safe:starting:opacity-0 motion-safe:starting:translate-y-6 transition-all duration-700 delay-450"
        >
          <Button
            href="/demo"
            size="lg"
            class="btn-shine glow-primary transition-all duration-200 hover:-translate-y-0.5"
            data-umami-event="Proefaccount CTA"
          >
            Demo inplannen
            <ArrowRight class="size-5" />
          </Button>
          <Button
            href="/contact"
            size="lg"
            variant="outline"
            class="bg-white/50 backdrop-blur-sm transition-all duration-200 hover:-translate-y-0.5"
          >
            Neem contact op
          </Button>
        </div>
      </div>

      <!-- Hero visual: zelfspelende Insync AI demo in app-frame -->
      <div
        id="hero-demo-wrap"
        class="relative mt-16 sm:mt-24 mx-auto max-w-2xl origin-bottom will-change-transform motion-safe:starting:opacity-0 motion-safe:starting:translate-y-12 transition-[opacity,translate] duration-1000 delay-400"
      >
        <!-- glow -->
        <div
          class="absolute -inset-8 -z-10 bg-gradient-to-tr from-primary/20 via-rose/10 to-accent/15 blur-3xl rounded-[3rem]"
          aria-hidden="true"
        >
        </div>

        <div id="hero-demo" aria-hidden="true">
          <!-- App window -->
          <div
            class="relative rounded-2xl border bg-white shadow-2xl shadow-primary/10 overflow-hidden text-left"
          >
            <!-- Top bar -->
            <div class="flex items-center gap-3 px-4 sm:px-5 py-3 border-b bg-muted/40">
              <div class="flex gap-1.5" aria-hidden="true">
                <span class="size-3 rounded-full bg-rose/40"></span>
                <span class="size-3 rounded-full bg-warning/40"></span>
                <span class="size-3 rounded-full bg-success/40"></span>
              </div>
              <div class="flex items-center gap-2 ml-1">
                <span
                  class="flex items-center justify-center size-6 rounded-md bg-primary/10 text-primary"
                >
                  <Bot class="size-4" />
                </span>
                <span class="text-sm font-medium">Insync AI</span>
              </div>
              <span class="ml-auto hidden sm:flex items-center gap-1.5 text-xs text-muted-foreground">
                <span class="relative flex size-1.5">
                  <span class="absolute inline-flex size-full animate-ping rounded-full bg-success opacity-60"
                  ></span>
                  <span class="relative inline-flex size-1.5 rounded-full bg-success"></span>
                </span>
                Verbonden met backoffice
              </span>
            </div>

            <!-- Chat body -->
            <div class="p-4 sm:p-6 space-y-4">
              <div class="flex justify-end" data-el="user-msg">
                <div
                  class="max-w-[80%] bg-primary text-primary-foreground rounded-2xl rounded-tr-sm px-4 py-2.5 text-sm"
                >
                  Werk het nieuwe adres van Jan de Vries bij en stuur hem een bevestiging.
                </div>
              </div>
              <div class="flex gap-2.5">
                <span
                  data-el="ai-avatar"
                  class="flex items-center justify-center size-7 rounded-lg bg-primary/10 text-primary shrink-0 mt-0.5"
                >
                  <Sparkles class="size-4" />
                </span>
                <div class="grid max-w-[85%]">
                  <!-- Thinking indicator -->
                  <div data-el="thinking" class="[grid-area:1/1] justify-self-start self-start">
                    <div
                      class="inline-flex items-center gap-1.5 bg-muted rounded-2xl rounded-tl-sm px-4 py-[1.125rem]"
                    >
                      <span class="thinking-dot size-1.5 rounded-full bg-foreground/50"></span>
                      <span class="thinking-dot size-1.5 rounded-full bg-foreground/50"></span>
                      <span class="thinking-dot size-1.5 rounded-full bg-foreground/50"></span>
                    </div>
                  </div>
                  <!-- AI reply + actiekaart -->
                  <div data-el="ai-msg" class="[grid-area:1/1] space-y-2.5">
                    <div class="bg-muted rounded-2xl rounded-tl-sm px-4 py-2.5 text-sm">
                      Ik heb het adres opgehaald en de wijziging klaargezet. Even bevestigen?
                    </div>
                    <div
                      class="rounded-xl border border-primary/30 bg-primary/[0.04] p-3 shadow-[0_0_28px_-10px] shadow-primary/25"
                    >
                      <div class="text-xs text-muted-foreground mb-1">Wijziging klaargezet</div>
                      <div class="text-sm font-medium mb-3">Adres → Dorpsstraat 12, 3500 Utrecht</div>
                      <div class="grid">
                        <div data-el="confirm-actions" class="[grid-area:1/1] flex gap-2">
                          <span
                            class="inline-flex items-center gap-1.5 rounded-lg bg-primary text-primary-foreground text-xs font-semibold px-3 py-1.5"
                          >
                            <CircleCheck class="size-3.5" /> Bevestigen
                          </span>
                          <span
                            class="inline-flex items-center rounded-lg border text-xs font-medium px-3 py-1.5"
                            >Weigeren</span
                          >
                        </div>
                        <div data-el="confirmed-badge" class="[grid-area:1/1] justify-self-start">
                          <span
                            class="inline-flex items-center gap-1.5 rounded-lg bg-success text-success-foreground text-xs font-semibold px-3 py-1.5"
                          >
                            <CircleCheck class="size-3.5" /> Bevestigd
                          </span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Input bar -->
            <div class="px-4 sm:px-5 py-3 border-t">
              <div class="flex items-center gap-2 rounded-xl border bg-muted/40 px-3.5 py-2.5">
                <span class="text-sm min-w-0 flex-1">
                  <span data-el="placeholder" class="text-muted-foreground">Typ een opdracht…</span>
                  <span data-el="typedwrap" class="break-words">
                    <span data-el="typed"></span><span
                      class="animate-caret inline-block w-px h-4 -mb-0.5 bg-foreground"></span>
                  </span>
                </span>
                <span
                  class="ml-auto flex items-center justify-center size-7 rounded-lg bg-primary text-primary-foreground shrink-0"
                >
                  <ArrowRight class="size-4" />
                </span>
              </div>
            </div>
          </div>

          <!-- Floating result cards -->
          <div data-el="float-1" class="hidden sm:block absolute -top-5 -right-4 lg:-right-10">
            <div
              class="animate-float-soft flex items-center gap-2.5 rounded-xl border bg-white shadow-lg px-3.5 py-2.5"
            >
              <span class="flex items-center justify-center size-7 rounded-lg bg-success/10 text-success">
                <CircleCheck class="size-4" />
              </span>
              <div class="text-xs">
                <div class="font-semibold">Adres bijgewerkt</div>
                <div class="text-muted-foreground">via RDW gecontroleerd</div>
              </div>
            </div>
          </div>
          <div data-el="float-2" class="hidden sm:block absolute -bottom-5 -left-4 lg:-left-10">
            <div
              class="animate-float-soft [animation-delay:1.5s] flex items-center gap-2.5 rounded-xl border bg-white shadow-lg px-3.5 py-2.5"
            >
              <span class="flex items-center justify-center size-7 rounded-lg bg-primary/10 text-primary">
                <Mail class="size-4" />
              </span>
              <div class="text-xs">
                <div class="font-semibold">Bevestiging verstuurd</div>
                <div class="text-muted-foreground">in jouw huisstijl</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Proof -->
  <section id="social-proof" class="py-12 sm:py-16">
    <div class="container">
      <div class="flex flex-col items-center">
        <p
          class="text-sm font-medium text-muted-foreground mb-8"
          data-aos="custom-fade-up"
          data-aos-duration="400"
          data-aos-once="true"
        >
          Vertrouwd door diverse partijen
        </p>
        <div class="flex items-center justify-center gap-12 sm:gap-20">
          {
            logos.map((logo, i) => (
              <a
                href={logo.href}
                target="_blank"
                data-aos="custom-fade-up"
                data-aos-duration="400"
                data-aos-delay={String(i * 100)}
                data-aos-once="true"
              >
                <img
                  src={logo.src}
                  alt={logo.alt}
                  class="h-8 sm:h-12 opacity-60 hover:opacity-100 hover:scale-105 transition-[opacity,scale] duration-300"
                />
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Probleem — Statement + Before/After -->
  <section id="pain-points" class="py-24 sm:py-32 grain relative overflow-hidden">
    <div
      class="absolute inset-0 bg-gradient-to-br from-primary/[0.03] via-transparent to-accent/[0.02] -z-0"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute -top-32 -left-32 size-80 rounded-full bg-primary/[0.05] blur-[100px] animate-aurora"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute -bottom-32 -right-32 size-80 rounded-full bg-accent/[0.04] blur-[100px] animate-aurora [animation-delay:-6s]"
      aria-hidden="true"
    >
    </div>

    <div class="container relative z-10">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
        <!-- Left: Statement -->
        <div class="max-md:flex max-md:flex-col max-md:items-center lg:w-3/5 text-center lg:text-left">
          <h2
            class="display !text-[2.25rem] sm:!text-[3rem] lg:!text-[3.5rem] text-balance mb-6 reveal-words"
          >
            <span class="word" style="--i:0">Verzekeren</span>
            <span class="word" style="--i:1">draait</span>
            <span class="word" style="--i:2">op</span>
            <span class="word" style="--i:3">administratie.</span>
            <span class="word" style="--i:4">Dat</span>
            <span class="word" style="--i:5">kan</span>
            <span class="word" style="--i:6"
              ><span class="bg-clip-text text-transparent bg-gradient-to-r from-primary to-accent"
                >anders</span
              >.</span
            >
          </h2>
          <p
            class="text-lg sm:text-xl text-muted-foreground text-pretty max-w-xl"
            data-aos="custom-fade-up"
            data-aos-duration="400"
            data-aos-delay="250"
            data-aos-once="true"
          >
            Je team verliest dagelijks uren aan handmatig, repeterend werk — werk dat de klant vaak
            zelf kan, of dat AI sneller doet. Insync neemt het over, bovenop je bestaande backoffice.
          </p>
        </div>

        <!-- Right: Before / After comparison -->
        <div class="lg:w-2/5 w-full flex flex-col items-center">
          <!-- Vandaag -->
          <div
            class="w-full p-6 rounded-2xl bg-muted/60 backdrop-blur-sm border border-border/60"
            data-aos="custom-fade-up"
            data-aos-duration="500"
            data-aos-delay="200"
            data-aos-once="true"
          >
            <div
              class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-5"
              data-aos="custom-fade-right"
              data-aos-duration="400"
              data-aos-delay="300"
              data-aos-once="true"
            >
              Vandaag
            </div>
            <ul class="space-y-3.5">
              <li
                class="flex items-center gap-3"
                data-aos="custom-fade-right"
                data-aos-duration="400"
                data-aos-delay="350"
                data-aos-once="true"
              >
                <FileText class="size-5 text-muted-foreground shrink-0" />
                <span class="font-medium">Handmatig overtypen tussen systemen</span>
              </li>
              <li
                class="flex items-center gap-3"
                data-aos="custom-fade-right"
                data-aos-duration="400"
                data-aos-delay="450"
                data-aos-once="true"
              >
                <Mail class="size-5 text-muted-foreground shrink-0" />
                <span class="font-medium">Herhaalvragen beantwoorden</span>
              </li>
              <li
                class="flex items-center gap-3"
                data-aos="custom-fade-right"
                data-aos-duration="400"
                data-aos-delay="550"
                data-aos-once="true"
              >
                <Phone class="size-5 text-muted-foreground shrink-0" />
                <span class="font-medium">Schades telefonisch intaken</span>
              </li>
            </ul>
          </div>

          <!-- Beam connector: data stroomt van oud naar nieuw -->
          <div
            class="relative my-2 h-12 w-px"
            aria-hidden="true"
            data-aos="custom-draw-down"
            data-aos-duration="500"
            data-aos-delay="700"
            data-aos-once="true"
          >
            <span
              class="absolute inset-0 w-px bg-gradient-to-b from-border via-primary/40 to-primary/70"
            ></span>
            <span
              class="beam-dot absolute left-1/2 top-0 size-2 rounded-full bg-primary shadow-[0_0_10px_2px] shadow-primary/40"
            ></span>
          </div>

          <!-- Met Insync -->
          <div
            class="relative w-full p-6 rounded-2xl bg-linear-to-br from-primary/15 via-primary/10 to-accent/10 border border-primary/30 shadow-lg shadow-primary/15 overflow-hidden"
            data-aos="custom-rise-pop"
            data-aos-duration="700"
            data-aos-delay="850"
            data-aos-once="true"
          >
            <Sparkles
              class="size-40 text-secondary/50 absolute bottom-0 right-0 translate-y-1/3 translate-x-1/3"
            />
            <div
              class="absolute -top-16 -right-16 size-40 rounded-full bg-primary/20 blur-3xl pointer-events-none animate-pulse-glow"
              aria-hidden="true"
            >
            </div>
            <div
              class="absolute -bottom-16 -left-16 size-32 rounded-full bg-accent/15 blur-3xl pointer-events-none animate-pulse-glow"
              style="animation-delay: 1.5s;"
              aria-hidden="true"
            >
            </div>

            <div class="relative flex items-center gap-2 mb-5">
              <span class="text-xs font-semibold uppercase tracking-widest text-primary">
                Met Insync
              </span>
            </div>

            <ul class="relative space-y-3">
              <li
                class="flex items-center gap-3"
                data-aos="custom-fade-right"
                data-aos-duration="400"
                data-aos-delay="1100"
                data-aos-once="true"
              >
                <div
                  class="flex items-center justify-center size-8 rounded-lg bg-white shadow-sm border border-primary/20 shrink-0"
                >
                  <CircleCheck class="size-4 text-primary" />
                </div>
                <span class="font-medium">Klant regelt het zelf in het portaal</span>
              </li>
              <li
                class="flex items-center gap-3"
                data-aos="custom-fade-right"
