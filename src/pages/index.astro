---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import CustomerPortal from "../assets/customer-portal/home.webp";
import InsyncAiChat from "../assets/insync-ai/chat.png";
import CustomerPortal2 from "../assets/customer-portal/mockup.webp";
import InsurancePortalCar from "../assets/insurance-portal/car-insurance-mockup.webp";
import InsyncAiOutput from "../assets/insync-ai/output.webp";
import IntegrationsHorizontal from "../assets/integrations-horizontal.svg";
import IntegrationsVertical from "../assets/integrations-vertical.svg";
import Background from "../assets/background.svg";
import LogoDuGardijn from "../assets/logos/du-gardijn.svg";
import LogoEfo from "../assets/logos/efo.svg";
import LogoJw from "../assets/logos/jw.svg";
import Button from "../components/ui/Button.astro";
import {
  ArrowRight,
  ArrowDown,
  ListChecks,
  MessageSquare,
  FileSearch,
  FileText,
  Mail,
  Phone,
  CircleCheck,
  Zap,
  Search,
  Blocks,
  RefreshCw,
  ShieldCheck,
  Sparkles,
  Bot,
  Mic,
  Monitor,
  Workflow,
  TriangleAlert,
  Layers,
  Clock,
} from "@lucide/astro";
import InsyncAiInput from "../assets/insync-ai/input.webp";
import InsyncAiTools from "../assets/insync-ai/tools.webp";
import Cta from "../components/sections/Cta.astro";

const aiTools = [
  {
    icon: ListChecks,
    tabTitle: "Klantadvies Tool",
    cardTitle: "Persoonlijk advies op basis van klantdata",
    description:
      "Persoonlijk advies op basis van klantgegevens en actuele polisvoorwaarden. Altijd onderbouwd, altijd compliant.",
    image: InsyncAiOutput,
    imageAlt: "Klantadvies Tool — advies op basis van klantdata",
    color: "bg-primary/10 text-primary",
  },
  {
    icon: ShieldCheck,
    tabTitle: "Schade Analyse",
    cardTitle: "Schadeclaims beoordelen in minuten",
    description:
      "AI analyseert schademeldingen, toetst ze aan polisvoorwaarden en keurt simpele claims direct goed. Complexe schades worden voorzien van een advies voor de behandelaar.",
    image: InsyncAiOutput,
    imageAlt: "Schade Analyse — automatische beoordeling van schadeclaims",
    color: "bg-rose/10 text-rose",
  },
  {
    icon: FileSearch,
    tabTitle: "Voorwaarden Vergelijker",
    cardTitle: "Polisvoorwaarden vergelijken in seconden",
    description:
      "Upload polisdocumenten en vergelijk voorwaarden, dekkingen en uitsluitingen. Ook los te gebruiken.",
    image: InsyncAiTools,
    imageAlt: "Voorwaarden Vergelijker — polisvoorwaarden vergelijken met AI",
    color: "bg-accent/10 text-accent",
  },
];

const solutions = [
  {
    label: "Klantportaal",
    title: "Digitaal gemak met AI-ondersteuning",
    description:
      "Jouw klanten krijgen een persoonlijk portaal met inzicht in verzekeringen, documenten en schades. Schademeldingen worden begeleid door een AI speech agent die klanten door het proces praat, terwijl AI de melding direct analyseert voor de schadebehandelaar.",
    image: CustomerPortal2,
    imageAlt: "Klantportaal met AI schademelding via speech agent",
    href: "/oplossingen/klantportaal",
    cta: "Klantportaal ontdekken",
    reverse: false,
  },
  {
    label: "Afsluitstraat",
    title: "Verzekeringen afsluiten met AI-begeleiding",
    description:
      "Klanten sluiten eenvoudig online verzekeringen af via een dynamische flow. Een ingebouwde AI chat assistent helpt bij vragen, legt dekkingsopties uit en begeleidt klanten door het volledige aanvraagproces.",
    image: InsurancePortalCar,
    imageAlt: "Digitale afsluitstraat met AI chat assistent",
    href: "/oplossingen/afsluitstraat",
    cta: "Afsluitstraat ontdekken",
    reverse: true,
  },
];

const advantages = [
  {
    title: "Geen 5 systemen meer",
    description:
      "Stel een vraag via chat of spraak. AI haalt het antwoord direct uit je backoffice.",
    icon: Search,
  },
  {
    title: "Direct gekoppeld",
    description:
      "Realtime data uit je backoffice. Werkt bovenop Novulo, Anva, CCS, eBlinqx en meer.",
    icon: RefreshCw,
  },
  {
    title: "Van dagen naar minuten",
    description: "Schadeanalyses, poliswijzigingen en klantadvies — automatisch verwerkt door AI.",
    icon: Sparkles,
  },
  {
    title: "Modulair platform",
    description:
      "Begin met het klantportaal. Voeg de afsluitstraat of AI-tools toe wanneer je er klaar voor bent.",
    icon: Blocks,
  },
];

const journeySteps = [
  {
    step: "01",
    icon: Mic,
    title: "Klant meldt schade",
    description:
      "Via het klantportaal meldt de klant schade met de AI voice agent die het gesprek begeleidt.",
    color: "text-primary",
    bgColor: "bg-primary/10",
  },
  {
    step: "02",
    icon: ShieldCheck,
    title: "AI analyseert direct",
    description:
      "Insync AI beoordeelt de claim automatisch op basis van polisvoorwaarden en klantgegevens.",
    color: "text-rose",
    bgColor: "bg-rose/10",
  },
  {
    step: "03",
    icon: Bot,
    title: "Medewerker krijgt advies",
    description:
      "De schadebehandelaar ontvangt een kant-en-klare beoordeling met een onderbouwd advies.",
    color: "text-accent",
    bgColor: "bg-accent/10",
  },
];
---

<Layout>
  <!-- Hero -->
  <section id="hero" class="relative pt-28 sm:pt-36 2xl:pt-44 pb-20 sm:pb-28 overflow-hidden">
    <div
      class="absolute inset-x-0 top-0 h-svh -z-10"
      style="mask-image: linear-gradient(to bottom, black 60%, transparent);"
      aria-hidden="true"
    >
      <img
        src={Background.src}
        alt=""
        class="w-full h-full object-cover starting:opacity-0 starting:scale-120 transition-[opacity,scale] duration-2000 delay-800"
      />
    </div>

    <div class="container">
      <div class="max-w-4xl mx-auto text-center">
        <div
          class="starting:opacity-0 starting:translate-y-8 starting:scale-75 transition-all duration-500"
        >
          <div
            class="inline-flex items-center gap-2 rounded-xl border text-sm font-medium pl-1 py-1 pr-3 mb-6"
          >
            <span class="bg-foreground text-background rounded-lg inline-block px-2 py-1"
              >Nieuw</span
            >
            Schade melden via onze AI agent
          </div>
        </div>
        <h1
          class="display mb-6 starting:opacity-0 starting:translate-y-8 starting:scale-75 transition-all duration-800 delay-100"
        >
          Wij maken
          <span
            class="bg-clip-text text-transparent bg-gradient-to-r from-primary via-rose to-accent bg-[length:200%_auto] animate-[gradient-shift_6s_ease_infinite]"
          >
            verzekeren
          </span>
          makkelijker
        </h1>
        <p
          class="text-lg sm:text-xl text-muted-foreground max-w-2xl mx-auto mb-10 starting:opacity-0 starting:translate-y-8 starting:scale-75 transition-all duration-800 delay-200"
        >
          Voor intermediairs en hun klanten. Eén platform dat jouw administratie slimmer, sneller en
          toegankelijker maakt.
        </p>
        <div
          class="flex flex-col sm:flex-row justify-center gap-4 starting:opacity-0 starting:translate-y-8 starting:scale-75 transition-all duration-800 delay-300"
        >
          <Button href="/demo" size="lg" class="glow-primary" data-umami-event="Proefaccount CTA">
            Demo inplannen
            <ArrowRight class="size-5" />
          </Button>
          <Button href="/contact" size="lg" variant="outline" class="group">
            Neem contact op
          </Button>
        </div>
      </div>

      <!-- Hero visual with scroll-based zoom -->
      <div
        id="hero-image"
        class="relative mt-8 sm:mt-12 mx-auto will-change-transform starting:opacity-0 starting:translate-y-8 starting:scale-75 transition-[opacity,translate,scale] duration-1000 delay-500"
        style="transform: scale(0.85);"
      >
        <div class="relative rounded-2xl overflow-hidden glow-primary">
          <Image
            src={InsyncAiChat}
            alt="Insync platform overzicht"
            class="w-full rounded-2xl aspect-video object-cover object-top"
            widths={[640, 960, 1400]}
            sizes="100vw"
          />
          <div
            class="absolute inset-0 bg-gradient-to-t from-background/20 via-transparent to-transparent pointer-events-none"
          >
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Proof -->
  <section id="social-proof" class="py-12 sm:py-16">
    <div class="container">
      <div
        class="flex flex-col items-center"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-once="true"
      >
        <p class="text-sm font-medium text-muted-foreground mb-8">
          Vertrouwd door diverse partijen
        </p>
        <div class="flex items-center justify-center gap-12 sm:gap-20">
          <a href="https://dugardijn.nl" target="_blank">
            <img
              src={LogoDuGardijn.src}
              alt="Du Gardijn"
              class="h-8 sm:h-12 opacity-60 hover:opacity-100 transition-opacity duration-300"
            />
          </a>
          <a href="https://efo.nl" target="_blank">
            <img
              src={LogoEfo.src}
              alt="EFO Verzekeringen"
              class="h-8 sm:h-12 opacity-60 hover:opacity-100 transition-opacity duration-300"
            />
          </a>
          <a href="https://jw.nl" target="_blank">
            <img
              src={LogoJw.src}
              alt="JW"
              class="h-8 sm:h-12 opacity-60 hover:opacity-100 transition-opacity duration-300"
            />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Pain Points — Statement + Stats -->
  <section id="pain-points" class="py-24 sm:py-32 grain relative overflow-hidden">
    <!-- Background -->
    <div
      class="absolute inset-0 bg-gradient-to-br from-primary/[0.03] via-transparent to-accent/[0.02] -z-0"
      aria-hidden="true"
    >
    </div>
    <!-- Decorative orbs -->
    <div
      class="absolute -top-32 -left-32 size-80 rounded-full bg-primary/[0.05] blur-[100px]"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute -bottom-32 -right-32 size-80 rounded-full bg-accent/[0.04] blur-[100px]"
      aria-hidden="true"
    >
    </div>

    <div class="container relative z-10">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
        <!-- Left: Statement -->
        <div
          class="max-md:flex max-md:flex-col max-md:items-center lg:w-3/5 text-center lg:text-left"
          data-aos="custom-fade-up"
          data-aos-duration="400"
          data-aos-once="true"
        >
          <h2 class="display !text-[2.25rem] sm:!text-[3rem] lg:!text-[3.5rem] mb-6">
            Minder administratie. Meer tijd voor <span
              class="bg-clip-text text-transparent bg-gradient-to-r from-primary to-accent"
              >wat telt</span
            >.
          </h2>
          <p class="text-lg sm:text-xl text-muted-foreground max-w-xl">
            Je team verliest uren aan polismutaties, schadedossiers en klantvragen die de klant ook
            zelf kan oplossen. Insync lost dat op — met moderne tools voor je klant én je
            medewerkers, bovenop je huidige backoffice.
          </p>
        </div>

        <!-- Right: Before / After comparison -->
        <div class="lg:w-2/5 w-full flex flex-col items-center">
          <!-- Vandaag -->
          <div
            class="w-full p-6 rounded-2xl bg-muted/60 backdrop-blur-sm border border-border/60"
            data-aos="custom-fade-up"
            data-aos-duration="500"
            data-aos-delay="200"
            data-aos-once="true"
          >
            <div
              class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-5"
              data-aos="custom-fade-right"
              data-aos-duration="400"
              data-aos-delay="300"
              data-aos-once="true"
            >
              Vandaag
            </div>
            <ul class="space-y-3.5">
              <li
                class="flex items-center gap-3"
                data-aos="custom-fade-right"
                data-aos-duration="400"
                data-aos-delay="350"
                data-aos-once="true"
              >
                <FileText class="size-5 text-muted-foreground shrink-0" />
                <span class="font-medium">Mutaties handmatig invoeren</span>
              </li>
              <li
                class="flex items-center gap-3"
                data-aos="custom-fade-right"
                data-aos-duration="400"
                data-aos-delay="450"
                data-aos-once="true"
              >
                <Mail class="size-5 text-muted-foreground shrink-0" />
                <span class="font-medium">Herhaalvragen beantwoorden</span>
              </li>
              <li
                class="flex items-center gap-3"
                data-aos="custom-fade-right"
                data-aos-duration="400"
                data-aos-delay="550"
                data-aos-once="true"
              >
                <Phone class="size-5 text-muted-foreground shrink-0" />
                <span class="font-medium">Schades telefonisch intaken</span>
              </li>
            </ul>
          </div>

          <!-- Arrow connector -->
          <div
            class="my-4"
            data-aos="custom-draw-down"
            data-aos-duration="500"
            data-aos-delay="700"
            data-aos-once="true"
          >
            <ArrowDown class="size-5 text-primary animate-arrow-bob" aria-hidden="true" />
          </div>

          <!-- Met Insync -->
          <div
            class="relative w-full p-6 rounded-2xl bg-linear-to-br from-primary/15 via-primary/10 to-accent/10 border border-primary/30 shadow-lg shadow-primary/10 overflow-hidden"
            data-aos="custom-rise-pop"
            data-aos-duration="700"
            data-aos-delay="850"
            data-aos-once="true"
          >
            <Sparkles
              class="size-40 text-secondary/50 absolute bottom-0 right-0 translate-y-1/3 translate-x-1/3"
            />
            <!-- Decorative glow -->
            <div
              class="absolute -top-16 -right-16 size-40 rounded-full bg-primary/20 blur-3xl pointer-events-none animate-pulse-glow"
              aria-hidden="true"
            >
            </div>
            <div
              class="absolute -bottom-16 -left-16 size-32 rounded-full bg-accent/15 blur-3xl pointer-events-none animate-pulse-glow"
              style="animation-delay: 1.5s;"
              aria-hidden="true"
            >
            </div>

            <div class="relative flex items-center gap-2 mb-5">
              <!-- <div class="flex items-center justify-center size-5 rounded-full bg-primary">
                <Sparkles class="size-3 text-white" />
              </div> -->
              <span class="text-xs font-semibold uppercase tracking-widest text-primary">
                Met Insync
              </span>
            </div>

            <ul class="relative space-y-3">
              <li
                class="flex items-center gap-3"
                data-aos="custom-fade-right"
                data-aos-duration="400"
                data-aos-delay="1100"
                data-aos-once="true"
              >
                <div
                  class="flex items-center justify-center size-8 rounded-lg bg-white shadow-sm border border-primary/20 shrink-0"
                >
                  <CircleCheck class="size-4 text-primary" />
                </div>
                <span class="font-medium">Klant regelt zelf in portaal</span>
              </li>
              <li
                class="flex items-center gap-3"
                data-aos="custom-fade-right"
                data-aos-duration="400"
                data-aos-delay="1200"
                data-aos-once="true"
              >
                <div
                  class="flex items-center justify-center size-8 rounded-lg bg-white shadow-sm border border-primary/20 shrink-0"
                >
                  <MessageSquare class="size-4 text-primary" />
                </div>
                <span class="font-medium">AI-assistent beantwoordt vragen</span>
              </li>
              <li
                class="flex items-center gap-3"
                data-aos="custom-fade-right"
                data-aos-duration="400"
                data-aos-delay="1300"
                data-aos-once="true"
              >
                <div
                  class="flex items-center justify-center size-8 rounded-lg bg-white shadow-sm border border-primary/20 shrink-0"
                >
                  <Zap class="size-4 text-primary" />
                </div>
                <span class="font-medium">Schade-intake via chat</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Platform Journey — How it all comes together -->
  <section id="platform" class="py-20 sm:py-28 relative overflow-hidden">
    <!-- Subtle background -->
    <div
      class="absolute inset-0 bg-gradient-to-b from-muted/40 via-muted/20 to-transparent -z-10"
      aria-hidden="true"
    >
    </div>

    <div class="container relative z-10">
      <div
        class="max-w-3xl mx-auto text-center mb-16"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-once="true"
      >
        <span class="label mb-4 inline-block">Eén platform</span>
        <h2 class="mb-4">Drie oplossingen die samenwerken</h2>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          Het klantportaal, de afsluitstraat en Insync AI vormen samen één platform. Elke stap in
          het proces is verbonden — van klantcontact tot afhandeling.
        </p>
      </div>

      <!-- Journey steps with connecting line -->
      <div class="max-w-5xl mx-auto relative">
        <!-- Horizontal connector line (desktop) -->
        <div
          class="hidden md:block absolute top-[5.5rem] left-[calc(16.67%-0.5rem)] right-[calc(16.67%-0.5rem)] h-px bg-gradient-to-r from-primary/20 via-rose/20 to-accent/20 z-0"
          aria-hidden="true"
        >
        </div>

        <div class="grid md:grid-cols-3 gap-6 lg:gap-8 relative z-10">
          {
            journeySteps.map((step, i) => (
              <div
                class="relative"
                data-aos="custom-fade-up"
                data-aos-duration="400"
                data-aos-delay={String(i * 100)}
                data-aos-once="true"
              >
                {/* Step number circle on the line */}
                <div class="flex justify-center mb-6">
                  <div
                    class:list={[
                      "flex items-center justify-center size-14 rounded-2xl shadow-sm border border-border/60 bg-white",
                      step.color,
                    ]}
                  >
                    <step.icon class="size-6" />
                  </div>
                </div>

                {/* Card content */}
                <div class="text-center p-6 sm:p-8 rounded-2xl bg-white border border-border/60 shadow-sm hover:shadow-md transition-shadow duration-300">
                  <span
                    class:list={[
                      "text-xs font-semibold uppercase tracking-widest mb-3 block",
                      step.color,
                    ]}
                  >
                    {step.step === "01"
                      ? "Klantportaal"
                      : step.step === "02"
                        ? "Insync AI"
                        : "Medewerkersportaal"}
                  </span>
                  <h4 class="text-lg font-semibold mb-2">{step.title}</h4>
                  <p class="text-muted-foreground text-sm">{step.description}</p>
                </div>
              </div>
            ))
          }
        </div>

        <div
          class="mt-12 text-center"
          data-aos="custom-fade-up"
          data-aos-duration="400"
          data-aos-delay="300"
          data-aos-once="true"
        >
          <p class="text-sm text-muted-foreground">
            Dit is slechts één voorbeeld. Alle oplossingen zijn modulair inzetbaar en komen samen in
            één omgeving.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- AI Assistent -->
  <section id="ai-assistent" class="relative py-24 sm:py-32 grain">
    <div class="container relative z-10">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
        <div class="lg:w-1/2 text-center lg:text-left">
          <span
            class="label mb-4 inline-block"
            data-aos="custom-fade-up"
            data-aos-duration="400"
            data-aos-once="true">Insync AI</span
          >
          <h2
            class="mb-4"
            data-aos="custom-fade-up"
            data-aos-duration="400"
            data-aos-delay="100"
            data-aos-once="true"
          >
            Het centrale portaal voor jouw medewerkers
          </h2>
          <p
            class="text-lg text-muted-foreground mb-8"
            data-aos="custom-fade-up"
            data-aos-duration="400"
            data-aos-delay="200"
            data-aos-once="true"
          >
            Eén plek waar medewerkers via chat of spraak hun backoffice aansturen. Van klantgegevens
            opvragen en polissen vergelijken tot schades afhandelen en communicatie versturen.
            Gecombineerd met AI-tools die het echte denkwerk uit handen nemen.
          </p>
          <div
            data-aos="custom-fade-up"
            data-aos-duration="400"
            data-aos-delay="300"
            data-aos-once="true"
          >
            <Button href="/oplossingen/ai-assistent" size="lg" class="group">
              Ontdek Insync AI
              <ArrowRight class="size-5 group-hover:translate-x-0.5 duration-150" />
            </Button>
          </div>
        </div>
        <div
          class="lg:w-1/2"
          data-aos="custom-zoom-in"
          data-aos-duration="600"
          data-aos-delay="200"
          data-aos-once="true"
        >
          <div class="rounded-2xl overflow-hidden border bg-muted/30">
            <Image
              src={InsyncAiOutput}
              alt="Insync AI — medewerkersportaal met chat en AI-tools"
              class="w-full"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- AI Tools -->
  <section id="ai-tools" class="py-20 sm:py-28">
    <div class="container">
      <div
        class="max-w-3xl mx-auto text-center mb-16"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-once="true"
      >
        <span class="label mb-4 inline-block">AI Tools</span>
        <h2>Slimme tools die het werk lichter maken</h2>
      </div>

      <div
        class="card-stack relative min-h-[28rem] pt-14 max-w-4xl mx-auto"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-delay="100"
        data-aos-once="true"
      >
        {
          aiTools.map((tool, i) => (
            <div
              class:list={[
                "card-stack-item absolute top-14 inset-x-0 min-h-96 flex flex-col bg-white rounded-[1.25rem] border-2 border-background shadow-lg overflow-hidden cursor-pointer",
                i === 0 && "is-front backdrop-blur-3xl bg-white/70 cursor-default",
              ]}
              style={`--stack-pos: ${i}; --stack-z: ${10 - i};`}
            >
              <div class="flex items-center gap-3 px-6 py-3.5 font-medium text-lg bg-[hsl(240_6%_95%)] rounded-t-[1.25rem] rounded-b-md border-b border-border/80">
                <div
                  class:list={[
                    "flex items-center justify-center size-9 rounded-lg shrink-0",
                    tool.color,
                  ]}
                >
                  <tool.icon class="size-5" />
                </div>
                <span>{tool.tabTitle}</span>
              </div>
              <div class="flex flex-col lg:flex-row gap-8 overflow-hidden flex-1">
                <div class="lg:w-2/5 shrink-0 p-6 sm:p-8 pb-0 sm:pt-16">
