  <Cta />
</Layout>

<script is:inline>
  document.addEventListener("click", function (e) {
    var clicked = e.target.closest(".card-stack-item");
    if (!clicked || clicked.classList.contains("is-front")) return;

    var stack = clicked.closest(".card-stack");
    var cards = Array.from(stack.querySelectorAll(".card-stack-item"));

    // Move clicked card to front
    cards.forEach(function (card) {
      card.classList.remove("is-front");
    });
    clicked.classList.add("is-front");

    // Recalculate stack positions: front card = 0, rest ordered by DOM position
    var pos = 1;
    cards.forEach(function (card) {
      if (card === clicked) {
        card.style.setProperty("--stack-pos", "0");
        card.style.setProperty("--stack-z", "10");
      } else {
        card.style.setProperty("--stack-pos", String(pos));
        card.style.setProperty("--stack-z", String(10 - pos));
        pos++;
      }
    });
  });
</script>
