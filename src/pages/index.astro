---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import CustomerPortal from "../assets/customer-portal/home.webp";
import CustomerPortal2 from "../assets/customer-portal/mockup.webp";
import InsurancePortalCar from "../assets/insurance-portal/car-insurance-mockup.webp";
import InsyncLaptopMockup from "../assets/insync-laptop-mockup.webp";
import IntegrationsHorizontal from "../assets/integrations-horizontal.svg";
import IntegrationsVertical from "../assets/integrations-vertical.svg";
import Button from "../components/ui/Button.astro";
import { ArrowRight, HeartHandshake, Files, Zap, Blocks, MessageSquare, Sparkles } from "@lucide/astro";
import Cta from "../components/sections/Cta.astro";

const features = [
  {
    title: "Minder handwerk, meer advies",
    description: "AI en self-service nemen repeterend werk uit handen, zodat jij tijd overhoudt voor je klant.",
    icon: HeartHandshake,
  },
  {
    title: "Altijd volledig en actueel",
    description: "Realtime data uit je backoffice. Veilig en compliant.",
    icon: Files,
  },
  {
    title: "Van vraag naar actie",
    description: "Klanten en medewerkers regelen zaken direct digitaal — AI zet het werk voor je klaar.",
    icon: Zap,
  },
  {
    title: "Meegroeien met je dienstverlening",
    description: "Kies alleen wat je nodig hebt. Uitbreiden kan altijd.",
    icon: Blocks,
  },
];
---

<Layout>
  <section
    id="hero"
    class="pt-16 sm:pt-24 2xl:pt-32 pb-16 sm:pb-24 xl:pb-20 2xl:pb-28 overflow-x-clip"
  >
    <div class="container">
      <div class="flex flex-col lg:flex-row items-center xl:items-start 2xl:items-center gap-24">
        <div>
          <div class="flex flex-col items-center lg:items-start space-y-4">
            <div class="starting:opacity-0 starting:translate-y-2 transition-all duration-500">
              <a
                href="/oplossingen/insync-ai"
                class="inline-flex items-center border rounded-full text-sm px-3 py-1 hover:bg-muted duration-150"
              >
                <div class="size-1.5 rounded-full bg-primary mr-2 shrink-0"></div>
                <div>
                  <span class="font-bold mr-1">Nieuw!</span>Insync AI · chat met je backoffice
                </div>
              </a>
            </div>
            <h1
              class="display text-center lg:text-left bg-clip-text text-transparent bg-gradient-to-t from-[#16136C] to-foreground mb-4 starting:opacity-0 starting:translate-y-2 transition-all duration-500 delay-150"
            >
              Minder administratie, meer tijd voor advies.
            </h1>
            <p
              class="max-w-3xl w-full text-center lg:text-left sm:text-lg mb-10 starting:opacity-0 starting:translate-y-2 transition-all duration-500 delay-300"
            >
              Insync is het AI-platform voor verzekeraars, volmachten en adviseurs. Met een slim
              klantportaal én AI die rechtstreeks met je backoffice werkt, neem je administratief
              werk weg en houd je tijd over voor advies. Snel live en volledig in je eigen huisstijl.
            </p>
          </div>

          <div
            class="flex flex-col justify-center lg:justify-start sm:flex-row gap-4 starting:opacity-0 starting:translate-y-2 transition-all duration-500 delay-450"
          >
            <Button
              href="/demo"
              size="lg"
              class="shadow-[0_0_25px_-5px_var(--color-primary)]"
              data-umami-event="Proefaccount CTA">Demo inplannen</Button
            >
            <Button href="/contact" size="lg" variant="outline" class="group">
              Praat met een expert
              <ArrowRight class="group-hover:translate-x-0.5 size-6 duration-150" />
            </Button>
          </div>
        </div>
        <div class="relative sm:w-[560px] grid place-items-center mx-auto">
          <Image
            src={CustomerPortal}
            alt="Klantportaal"
            class="w-[280px] starting:opacity-0 starting:scale-95 transition-all duration-1000 delay-600"
          />
          <div
            class="hidden sm:flex absolute top-12 -left-2 lg:-left-6 z-10 items-center gap-3 bg-background/95 backdrop-blur border rounded-2xl shadow-lg px-4 py-3 starting:opacity-0 starting:-translate-x-2 transition-all duration-700 delay-[900ms]"
          >
            <div
              class="flex items-center justify-center size-9 rounded-full bg-secondary text-primary shrink-0"
            >
              <MessageSquare class="size-5" />
            </div>
            <div class="text-sm leading-tight">
              <div class="font-medium">Klant in het portaal</div>
              <div class="text-muted-foreground">"Stuur mijn polisblad"</div>
            </div>
          </div>
          <div
            class="hidden sm:flex absolute bottom-12 -right-2 lg:-right-6 z-10 items-center gap-3 bg-background/95 backdrop-blur border rounded-2xl shadow-lg px-4 py-3 starting:opacity-0 starting:translate-x-2 transition-all duration-700 delay-[1100ms]"
          >
            <div
              class="flex items-center justify-center size-9 rounded-full bg-primary text-primary-foreground shrink-0"
            >
              <Sparkles class="size-5" />
            </div>
            <div class="text-sm leading-tight">
              <div class="font-medium">Insync AI</div>
              <div class="text-muted-foreground">Klaargezet in je backoffice</div>
            </div>
          </div>
          <div class="starting:opacity-0 transition-all duration-2000 delay-1000 -z-10">
            <div
              class="absolute -top-[64px] -left-[64px] bg-accent/10 size-[500px] rounded-[120px] blur-[150px]"
            >
            </div>
            <div
              class="absolute -bottom-[64px] -right-[64px] bg-primary/15 size-[500px] rounded-[120px] blur-[150px]"
            >
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!--<section id="social-proof" class="py-12 sm:py-16 starting:opacity-0 duration-600 delay-600">-->
  <!--  <div class="container">-->
  <!--    <div class="flex flex-col items-center">-->
  <!--      <h1 class="text-lg font-medium text-muted-foreground mb-12 sm:mb-16">Vertrouwd door intermediairs</h1>-->
  <!--      <ul class="flex items-center gap-32">-->
  <!--        <li>-->
  <!--          <a href="https://dugardijn.nl">-->
  <!--            <Image src={DuGardijn} alt="du Gardijn" class="grayscale hover:grayscale-0 duration-300"/>-->
  <!--          </a>-->
  <!--        </li>-->
  <!--      </ul>-->
  <!--    </div>-->
  <!--  </div>-->
  <!--</section>-->

  <section id="customer-portal" class="py-20 sm:py-28">
    <div class="container">
      <div class="flex flex-col lg:flex-row justify-between items-center gap-16 lg:gap-32">
        <div data-aos="custom-fade-up" data-aos-duration="400" data-aos-once="true">
          <div class="text-primary font-medium mb-2">Klantportaal</div>
          <h1 class="mb-4">Digitaal gemak voor je klant</h1>
          <p class="mb-10">
            Jouw klant verwacht overzicht, snelheid en eenvoud. Met Insync geef je hen een
            persoonlijk portaal waar ze zelf hun verzekeringen, documenten, facturen en schades
            regelen. En een ingebouwde AI-assistent die hun eigen dossier kent en direct vragen
            beantwoordt of acties klaarzet. Veilig en altijd beschikbaar.
          </p>
          <Button href="/oplossingen/klantportaal" size="lg" class="w-full sm:w-auto">
            Klantportaal ontdekken
            <ArrowRight class="size-5" />
          </Button>
        </div>
        <div
          class="lg:max-w-[640px] w-full"
          data-aos="custom-zoom-in"
          data-aos-duration="400"
          data-aos-delay="400"
          data-aos-once="true"
        >
          <Image src={CustomerPortal2} alt="Klantportaal" class="rounded-3xl" />
        </div>
      </div>
    </div>
  </section>

  <section id="insurance-portal" class="py-20 sm:py-28">
    <div class="container">
      <div class="flex flex-col lg:flex-row justify-between items-center gap-16 lg:gap-32">
        <div
          class="order-last lg:order-first lg:max-w-[560px] w-full"
          data-aos="custom-zoom-in"
          data-aos-duration="400"
          data-aos-delay="400"
          data-aos-once="true"
        >
          <Image
            src={InsurancePortalCar}
            alt="Digitale afsluitstraat voor verzekeringen"
            class="rounded-3xl"
            width={560}
            height={560}
            loading="lazy"
          />
        </div>
        <div data-aos="custom-fade-up" data-aos-duration="400" data-aos-once="true">
          <div class="text-primary font-medium mb-2">Digitale afsluitstraat</div>
          <h2 class="h1 mb-4">Efficiënt en veilig verzekeringen afsluiten</h2>
          <p class="mb-10">
            Laat klanten eenvoudig online verzekeringen aanvragen en afsluiten. Met de dynamische
            afsluitstraat van Insync worden aanvragen automatisch verwerkt in je administratie,
            zonder extra handwerk.
          </p>
          <Button href="/oplossingen/afsluitstraat" size="lg" class="w-full sm:w-auto">
            Afsluitstraat ontdekken
            <ArrowRight class="size-5" aria-hidden="true" />
          </Button>
        </div>
      </div>
    </div>
  </section>

  <section id="insync-ai" class="py-20 sm:py-28">
    <div class="container">
      <div class="flex flex-col lg:flex-row justify-between items-center gap-16 lg:gap-32">
        <div data-aos="custom-fade-up" data-aos-duration="400" data-aos-once="true">
          <div class="text-primary font-medium mb-2">Insync AI</div>
          <h2 class="h1 mb-4">Laat AI je backoffice bedienen</h2>
          <p class="mb-10">
            Geef in gewone taal een opdracht en Insync AI doet het werk: klantgegevens opzoeken,
            schades en taken voorbereiden, e-mails opstellen. Opzoeken gaat direct, elke wijziging
            zet de AI alvast klaar — jij bevestigt met één klik. Zo houd je grip én tijd over.
          </p>
          <Button href="/oplossingen/insync-ai" size="lg" class="w-full sm:w-auto">
            Insync AI ontdekken
            <ArrowRight class="size-5" />
          </Button>
        </div>
        <div
          class="lg:max-w-[640px] w-full"
          data-aos="custom-zoom-in"
          data-aos-duration="400"
          data-aos-delay="400"
          data-aos-once="true"
        >
          <Image src={InsyncLaptopMockup} alt="Insync AI" class="rounded-3xl" />
        </div>
      </div>
    </div>
  </section>

  <section id="features" class="py-20 sm:py-28">
    <div class="container">
      <div
        class="flex flex-col lg:flex-row justify-between items-end gap-4 lg:gap-10 mb-16"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-once="true"
      >
        <div class="lg:max-w-[600px]">
          <div class="text-primary font-medium mb-2">Voordelen van Insync</div>
          <h1>Efficiëntie voor jou. Gemak voor je klant.</h1>
        </div>
        <p class="lg:max-w-[640px]">
          Met Insync haal je direct meetbaar resultaat: minder losse klantvragen, meer grip op je
          dossiers en een efficiënter werkproces zonder extra tools.
        </p>
      </div>

      <ul
        class="grid md:grid-cols-2 xl:grid-cols-4 border rounded-2xl"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-delay="200"
        data-aos-once="true"
      >
        {
          features.map((feature) => (
            <li class="flex p-6 border-b border-r md:max-xl:nth-[3]:border-b-0 last:border-0 xl:border-b-0">
              <feature.icon class="size-6 text-primary shrink-0 mt-0.5 mr-3" />
              <div>
                <div class="text-lg font-medium mb-1">{feature.title}</div>
                <p class="text-muted-foreground">{feature.description}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section id="integrations" class="bg-muted/50 py-20 sm:py-28">
    <div class="container">
      <div class="flex flex-col items-center">
        <h1
          class="max-w-[720px] text-center lg:mb-16"
          data-aos="custom-fade-up"
          data-aos-duration="400"
          data-aos-once="true"
        >
          Naadloos verbonden met jouw systeemlandschap
        </h1>
      </div>
    </div>
    <Image
      src={IntegrationsHorizontal}
      alt="Integraties van Insync"
      class="hidden lg:block max-h-80 mx-auto"
      data-aos="custom-zoom-in"
      data-aos-duration="400"
      data-aos-delay="200"
      data-aos-once="true"
    />
    <Image
      src={IntegrationsVertical}
      alt="Integraties van Insync"
      class="lg:hidden w-full max-w-[560px] mx-auto"
      data-aos="custom-zoom-in"
      data-aos-duration="400"
      data-aos-delay="200"
      data-aos-once="true"
    />
  </section>

  <Cta />
</Layout>
