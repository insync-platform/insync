---
import Layout from "../layouts/Layout.astro";
import { Check } from "@lucide/astro";
import DemoForm from "../components/DemoForm.astro";
import Cta from "../components/sections/Cta.astro";
---

<Layout
  title="Demo inplannen"
  description="Plan een gratis demo en ontdek hoe Insync verzekeraars, volmachten en adviseurs helpt met agentic AI, een klantportaal en een afsluitstraat."
>
  <!-- Hero -->
  <section class="relative pt-28 sm:pt-36 2xl:pt-44 pb-16 sm:pb-20 overflow-hidden">
    <!-- Background decoration -->
    <div
      class="absolute -top-32 left-1/2 -translate-x-1/2 size-[600px] rounded-full bg-primary/[0.04] blur-[120px] -z-10"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute -top-20 -right-32 size-80 rounded-full bg-accent/[0.04] blur-[100px] -z-10"
      aria-hidden="true"
    >
    </div>

    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <span
          class="label mb-6 inline-block starting:opacity-0 starting:translate-y-4 transition-all duration-500"
        >
          Demo
        </span>
        <h1
          class="display mb-6 starting:opacity-0 starting:translate-y-4 transition-all duration-500 delay-100"
        >
          Demo inplannen
        </h1>
        <p
          class="text-lg sm:text-xl text-muted-foreground max-w-2xl mx-auto starting:opacity-0 starting:translate-y-4 transition-all duration-500 delay-200"
        >
          Ontdek hoe je met Insync administratief werk laat overnemen door AI — van je klantportaal
          tot je backoffice. Kosteloos en zonder verplichtingen.
        </p>
      </div>
    </div>
  </section>

  <!-- Demo Form -->
  <section class="pb-16 sm:pb-20">
    <div class="container">
      <div class="max-w-2xl mx-auto">
        <DemoForm />
      </div>
    </div>
  </section>

  <!-- What to expect -->
  <section class="pb-20 sm:pb-28">
    <div class="container">
      <div
        class="max-w-3xl mx-auto flex flex-wrap justify-center gap-x-8 gap-y-4 text-sm text-muted-foreground"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-once="true"
      >
        <span class="flex items-center gap-2">
          <Check class="size-4 text-green-500" />
          Een korte kennismaking
        </span>
        <span class="flex items-center gap-2">
          <Check class="size-4 text-green-500" />
          Toegang tot onze demo-omgeving
        </span>
        <span class="flex items-center gap-2">
          <Check class="size-4 text-green-500" />
          Koppeling met je backoffice
        </span>
        <span class="flex items-center gap-2">
          <Check class="size-4 text-green-500" />
          Vragen over jouw situatie
        </span>
      </div>
    </div>
  </section>

  <Cta
    heading="Liever eerst even bellen?"
    text="Neem vrijblijvend contact op en ontdek wat Insync voor jouw organisatie kan betekenen."
  />
</Layout>
