---
import Layout from "../layouts/Layout.astro";
import { Phone, MessageCircle, Mail, ChevronDown } from "@lucide/astro";
import ContactForm from "../components/ContactForm.astro";
import Cta from "../components/sections/Cta.astro";

const contactMethods = [
  {
    icon: Phone,
    label: "Telefoon",
    value: "06 1828 2389",
    href: "tel:0618282389",
    color: "bg-primary/10 text-primary",
    borderColor: "border-primary/20 hover:border-primary/40",
  },
  {
    icon: MessageCircle,
    label: "WhatsApp",
    value: "06 1828 2389",
    href: "https://wa.me/31618282389",
    color: "bg-rose/10 text-rose",
    borderColor: "border-rose/20 hover:border-rose/40",
  },
  {
    icon: Mail,
    label: "E-mailadres",
    value: "hello@insync.insure",
    href: "mailto:hello@insync.insure",
    color: "bg-accent/10 text-accent",
    borderColor: "border-accent/20 hover:border-accent/40",
  },
];

const faqs = [
  {
    question: "Wat is Insync precies?",
    answer:
      "Insync is een AI-first platform dat speciaal is ontwikkeld voor verzekeringsadviseurs. Het combineert een klantportaal, afsluitstraat en AI-tools in één omgeving — zodat jij minder tijd kwijt bent aan administratie en meer aan advies.",
  },
  {
    question: "Moet ik mijn huidige backoffice vervangen?",
    answer:
      "Nee. Insync werkt bovenop je bestaande systemen zoals Novulo, Anva, CCS en eBlinqx. We vervangen niets, maar maken je huidige omgeving slimmer en toegankelijker met AI.",
  },
  {
    question: "Hoe lang duurt het om Insync te implementeren?",
    answer:
      "Dat hangt af van welke modules je wilt inzetten. Het klantportaal kan vaak binnen enkele weken live staan. Tijdens de demo bespreken we een realistisch tijdspad op basis van jouw situatie.",
  },
  {
    question: "Is mijn data veilig bij Insync?",
    answer:
      "Absoluut. We werken met Europese hosting, versleutelde verbindingen en volgen de AVG-richtlijnen strikt. Klantdata wordt niet gebruikt voor het trainen van AI-modellen.",
  },
  {
    question: "Kan ik Insync eerst uitproberen?",
    answer:
      "Ja, we bieden een vrijblijvende demo aan waarin we het platform laten zien op basis van jouw eigen situatie. Zo kun je direct zien wat Insync voor jouw kantoor kan betekenen.",
  },
  {
    question: "Wat kost Insync?",
    answer:
      "De kosten hangen af van de modules die je afneemt en de grootte van je kantoor. We werken met een transparant maandelijks abonnement. Neem contact op of plan een demo voor een passend voorstel.",
  },
];
---

<Layout
  title="Contact"
  description="Vragen over Insync voor jouw verzekeringsadviseurskantoor? Neem vrijblijvend contact op over ons klantportaal of AI-oplossingen."
>
  <!-- Hero -->
  <section class="relative pt-28 sm:pt-36 2xl:pt-44 pb-16 sm:pb-20 overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute -top-32 left-1/2 -translate-x-1/2 size-[600px] rounded-full bg-primary/[0.04] blur-[120px] -z-10" aria-hidden="true"></div>
    <div class="absolute -top-20 -right-32 size-80 rounded-full bg-accent/[0.04] blur-[100px] -z-10" aria-hidden="true"></div>

    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <span
          class="label mb-6 inline-block starting:opacity-0 starting:translate-y-4 transition-all duration-500"
        >
          Contact
        </span>
        <h1
          class="display mb-6 starting:opacity-0 starting:translate-y-4 transition-all duration-500 delay-100"
        >
          We horen graag van je
        </h1>
        <p
          class="text-lg sm:text-xl text-muted-foreground max-w-2xl mx-auto starting:opacity-0 starting:translate-y-4 transition-all duration-500 delay-200"
        >
          Heb je een vraag, wil je een demo inplannen of gewoon even sparren?
          We reageren meestal binnen een werkdag.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Methods -->
  <section class="pb-16 sm:pb-20">
    <div class="container">
      <div
        class="grid sm:grid-cols-3 gap-4 max-w-3xl mx-auto starting:opacity-0 starting:translate-y-4 transition-all duration-500 delay-300"
      >
        {
          contactMethods.map((method) => (
            <a
              href={method.href}
              class:list={[
                "group flex flex-col items-center text-center p-6 rounded-2xl bg-white border shadow-sm hover:shadow-md transition-all duration-300",
                method.borderColor,
              ]}
            >
              <div
                class:list={[
                  "flex items-center justify-center size-12 rounded-xl mb-4 group-hover:scale-110 transition-transform duration-300",
                  method.color,
                ]}
              >
                <method.icon class="size-5" />
              </div>
              <span class="text-sm font-semibold mb-1">{method.label}</span>
              <span class="text-sm text-muted-foreground">{method.value}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="pb-20 sm:pb-28">
    <div class="container">
      <div
        class="max-w-2xl mx-auto"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-once="true"
      >
        <ContactForm />
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 sm:py-28 bg-muted/20 grain relative overflow-hidden">
    <div class="absolute -top-32 -left-32 size-80 rounded-full bg-primary/[0.04] blur-[100px]" aria-hidden="true"></div>
    <div class="absolute -bottom-32 -right-32 size-80 rounded-full bg-accent/[0.04] blur-[100px]" aria-hidden="true"></div>

    <div class="container relative z-10">
      <div
        class="max-w-3xl mx-auto text-center mb-12"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-once="true"
      >
        <span class="label mb-4 inline-block">FAQ</span>
        <h2>Veelgestelde vragen</h2>
      </div>

      <div class="max-w-2xl mx-auto space-y-3">
        {
          faqs.map((faq, i) => (
            <div
              class="faq-item rounded-2xl border border-border/60 bg-white shadow-sm overflow-hidden"
              data-aos="custom-fade-up"
              data-aos-duration="400"
              data-aos-delay={String(i * 60)}
              data-aos-once="true"
            >
              <button
                class="faq-trigger flex items-center justify-between w-full text-left p-5 sm:p-6 cursor-pointer group"
                aria-expanded="false"
              >
                <span class="font-semibold pr-4">{faq.question}</span>
                <ChevronDown class="size-5 text-muted-foreground shrink-0 transition-transform duration-300 group-aria-expanded:rotate-180" />
              </button>
              <div class="faq-content grid grid-rows-[0fr] transition-[grid-template-rows] duration-300">
                <div class="overflow-hidden">
                  <p class="px-5 sm:px-6 pb-5 sm:pb-6 text-muted-foreground leading-relaxed">
                    {faq.answer}
                  </p>
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <div
        class="text-center mt-10"
        data-aos="custom-fade-up"
        data-aos-duration="400"
        data-aos-once="true"
      >
        <p class="text-muted-foreground">
          Staat je vraag er niet bij?{" "}
          <a href="mailto:hello@insync.insure" class="text-primary font-medium hover:underline">
            Stuur ons een e-mail
          </a>
        </p>
      </div>
    </div>
  </section>

  <Cta heading="Liever direct een demo?" text="Plan een vrijblijvende demo in en ontdek wat Insync voor jouw kantoor kan betekenen." />
</Layout>

<script is:inline>
  document.querySelectorAll('.faq-trigger').forEach(function (trigger) {
    trigger.addEventListener('click', function () {
      var item = trigger.closest('.faq-item');
      var content = item.querySelector('.faq-content');
      var isOpen = trigger.getAttribute('aria-expanded') === 'true';

      // Close all other items
      document.querySelectorAll('.faq-item').forEach(function (other) {
        if (other !== item) {
          other.querySelector('.faq-trigger').setAttribute('aria-expanded', 'false');
          other.querySelector('.faq-content').style.gridTemplateRows = '0fr';
        }
      });

      // Toggle current
      trigger.setAttribute('aria-expanded', String(!isOpen));
      content.style.gridTemplateRows = isOpen ? '0fr' : '1fr';
    });
  });
</script>
